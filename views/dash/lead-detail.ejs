<%- include('../partials/dash-top', { user: user, active: active, title: lead.name + '님' }) %>

<%
  function fmt(d){ try { return new Date(d).toLocaleString('ko-KR',{timeZone:'Asia/Seoul',month:'numeric',day:'numeric',hour:'2-digit',minute:'2-digit'}); } catch(e){ return '-'; } }
  var EL = {'목':'el-목','화':'el-화','토':'el-토','금':'el-금','수':'el-수'};
%>

<a class="backlink" href="/leads">← 신청자 목록</a>

<!-- 신청자 정보 -->
<div class="settings-block">
  <h2 class="section-h">신청자 정보
    <button type="button" class="edit-btn" id="btnEditLead">정보 수정</button>
  </h2>

  <div id="leadView">
  <div class="acc-row"><span>이름</span><b><%= lead.name %> <%= lead.gender || '' %></b></div>
  <div class="acc-row"><span>생년월일</span><b><%= lead.birth || '-' %> <%= lead.calendar || '' %></b></div>
  <div class="acc-row"><span>태어난 시간</span><b><%= (lead.hour && !/모름/.test(lead.hour)) ? lead.hour : '모름' %></b></div>
  <div class="acc-row"><span>지역</span><b><%= lead.region || '-' %></b></div>
  <div class="acc-row"><span>이메일</span><b><%= lead.email || '-' %></b></div>
  <% if (lead.phone) { %><div class="acc-row"><span>연락처</span><b><%= lead.phone %></b></div><% } %>
  <% if (lead.product) { %><div class="acc-row"><span>신청 상품</span><b><%= lead.product %></b></div><% } %>
  <div class="acc-row"><span>신청 경로</span><b><%= lead.source === '무료사주' ? '무료사주' : '상담 신청' %></b></div>
  <div class="acc-row"><span>신청 시각</span><b><%= fmt(lead.created_at) %></b></div>
  </div>

  <!-- 정보 수정 폼 -->
  <div id="leadEdit" style="display:none">
    <div class="ed-warn">생년월일·시간·지역을 바꾸면 사주가 달라집니다.
      이미 만든 리포트는 그대로 남으니, 바꾼 뒤 <b>리포트를 다시 만들어</b>주세요.</div>

    <div class="ed-grid">
      <label class="ed-f"><span>이름</span>
        <input type="text" id="edName" value="<%= lead.name || '' %>"></label>
      <label class="ed-f"><span>성별</span>
        <select id="edGender">
          <option value="" <%= !lead.gender ? 'selected' : '' %>>선택 안 함</option>
          <option value="남" <%= lead.gender === '남' ? 'selected' : '' %>>남</option>
          <option value="여" <%= lead.gender === '여' ? 'selected' : '' %>>여</option>
        </select></label>
      <label class="ed-f"><span>생년월일</span>
        <input type="text" id="edBirth" value="<%= lead.birth || '' %>" placeholder="1990-01-29"></label>
      <label class="ed-f"><span>달력</span>
        <select id="edCal">
          <% ['양력','음력','윤달'].forEach(function(c){ %>
            <option value="<%= c %>" <%= (lead.calendar || '양력') === c ? 'selected' : '' %>><%= c %></option>
          <% }); %>
        </select></label>
      <label class="ed-f"><span>태어난 시간</span>
        <input type="text" id="edHour" value="<%= lead.hour || '' %>" placeholder="모르면 비워두세요"></label>
      <label class="ed-f"><span>지역</span>
        <input type="text" id="edRegion" value="<%= lead.region || '' %>" placeholder="서울특별시"></label>
      <label class="ed-f wide"><span>이메일</span>
        <input type="email" id="edEmail" value="<%= lead.email || '' %>" placeholder="report@example.com"></label>
      <label class="ed-f wide"><span>연락처</span>
        <input type="text" id="edPhone" value="<%= lead.phone || '' %>" placeholder="010-0000-0000"></label>
    </div>

    <div class="ed-actions">
      <button type="button" class="ed-save" id="btnSaveLead">저장하기</button>
      <button type="button" class="ed-cancel" id="btnCancelLead">취소</button>
    </div>
  </div>

  <% if (lead.memo && String(lead.memo).trim()) { %>
    <div class="acc-row col"><span>묻고 싶은 것</span>
      <div class="memo-box"><%= lead.memo %></div>
      <div class="q-on">✓ 리포트에 <b>‘남겨주신 질문에 답합니다’</b> 장이 추가됩니다</div>
    </div>
  <% } else { %>
    <div class="acc-row col"><span>묻고 싶은 것</span>
      <div class="q-off">남긴 질문이 없어 <b>질문 답변 장은 들어가지 않습니다.</b><br>
      카카오톡 등으로 질문을 받으셨다면, 아래 <b>‘질문 추가’</b>에 적고 리포트를 만들어주세요.</div>
      <div class="q-add">
        <textarea id="qAdd" rows="2" placeholder="내담자가 궁금해하는 것을 적어주세요"></textarea>
        <button type="button" id="qSave">질문 저장</button>
      </div>
    </div>
  <% } %>

  <!-- 연인궁합 · 재회운용 상대방 정보 -->
  <div class="acc-row col"><span>상대방 정보</span>
    <% if (lead.partner_birth) { %>
      <div class="pt-on">💑 <b><%= lead.partner_name || '상대방' %></b>
        · <%= lead.partner_birth %> <%= lead.partner_calendar || '양력' %>
        · <%= lead.partner_hour || '시간 모름' %>
        <%= lead.partner_gender ? '· ' + lead.partner_gender : '' %><br>
        <span class="pt-note">연인궁합 · 재회운 리포트에 이 정보가 함께 반영됩니다</span>
      </div>
    <% } else { %>
      <div class="pt-off">연인궁합 · 재회운은 <b>상대방 생년월일</b>이 있으면 훨씬 정확합니다.<br>
      아래에 입력하면 새로 신청받지 않아도 바로 반영됩니다.</div>
    <% } %>
    <button type="button" class="pt-toggle" id="btnPartner">
      <%= lead.partner_birth ? '상대방 정보 수정' : '＋ 상대방 정보 입력' %>
    </button>

    <div id="partnerBox" style="display:none">
      <div class="pt-grid">
        <label class="pt-f"><span>상대방 이름</span>
          <input type="text" id="ptName" value="<%= lead.partner_name || '' %>" placeholder="선택"></label>
        <label class="pt-f"><span>성별</span>
          <select id="ptGender">
            <option value="" <%= !lead.partner_gender ? 'selected' : '' %>>선택 안 함</option>
            <option value="남" <%= lead.partner_gender === '남' ? 'selected' : '' %>>남</option>
            <option value="여" <%= lead.partner_gender === '여' ? 'selected' : '' %>>여</option>
          </select></label>
        <label class="pt-f"><span>생년월일</span>
          <input type="text" id="ptBirth" value="<%= lead.partner_birth || '' %>" placeholder="1990-01-29"></label>
        <label class="pt-f"><span>달력</span>
          <select id="ptCal">
            <% ['양력','음력','윤달'].forEach(function(c){ %>
              <option value="<%= c %>" <%= (lead.partner_calendar || '양력') === c ? 'selected' : '' %>><%= c %></option>
            <% }); %>
          </select></label>
        <label class="pt-f wide"><span>태어난 시간</span>
          <input type="text" id="ptHour" value="<%= lead.partner_hour || '' %>" placeholder="모르면 비워두세요"></label>
      </div>
      <div class="pt-actions">
        <button type="button" class="pt-save" id="btnPartnerSave">저장하기</button>
        <% if (lead.partner_birth) { %>
          <button type="button" class="pt-del" id="btnPartnerDel">삭제</button>
        <% } %>
      </div>
    </div>
  </div>

<style>
  .pt-on{font-size:14px;color:#2f7a4f;background:#eef7f0;border-radius:9px;padding:11px 13px;line-height:1.7}
  .pt-on b{color:#256b42}
  .pt-note{font-size:12.5px;color:#5d8a6f}
  .pt-off{font-size:13.5px;color:#8a6f3c;background:#fbf6ec;border:1px solid #ecdfc4;border-radius:9px;padding:11px 13px;line-height:1.65}
  .pt-toggle{margin-top:9px;padding:9px 15px;background:#fff;border:1px solid #ddd2b8;border-radius:8px;
    font-size:13.5px;font-weight:700;color:#8a6f3c;cursor:pointer}
  .pt-toggle:hover{border-color:#B59A62;background:#fbf6ec}
  .pt-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:12px}
  .pt-f{display:flex;flex-direction:column;gap:5px}
  .pt-f.wide{grid-column:1/-1}
  .pt-f span{font-size:12.5px;color:#8a8372;font-weight:600}
  .pt-f input,.pt-f select{border:1px solid #ddd2b8;border-radius:8px;padding:9px 11px;font-size:14px;font-family:inherit;background:#fff;color:#3a3527}
  .pt-f input:focus,.pt-f select:focus{outline:none;border-color:#B59A62}
  .pt-actions{display:flex;gap:8px;margin-top:12px}
  .pt-save{padding:10px 19px;background:#B59A62;color:#fff;border:0;border-radius:9px;font-weight:800;font-size:14px;cursor:pointer}
  .pt-del{padding:10px 16px;background:#fff;border:1px solid #e0c4c4;border-radius:9px;font-weight:700;font-size:13.5px;color:#b1544a;cursor:pointer}
  @media(max-width:600px){ .pt-grid{grid-template-columns:1fr} }
</style>
<script>
  (function(){
    var btn=document.getElementById('btnPartner'), box=document.getElementById('partnerBox');
    if(!btn||!box) return;
    btn.onclick=function(){ box.style.display=(box.style.display==='none')?'':'none'; };
    async function send(body){
      var r=await fetch('/leads/<%= lead.id %>/partner',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
      var d=await r.json(); if(!d.ok) throw new Error(d.error||'실패'); location.reload();
    }
    document.getElementById('btnPartnerSave').onclick=async function(){
      var v=function(id){var e=document.getElementById(id);return e?e.value.trim():'';};
      if(!v('ptBirth')){ alert('상대방 생년월일을 입력해주세요.'); return; }
      var b=this; b.disabled=true; b.textContent='저장중...';
      try{ await send({name:v('ptName'),gender:v('ptGender'),birth:v('ptBirth'),calendar:v('ptCal'),hour:v('ptHour')}); }
      catch(e){ alert('저장 실패: '+e.message); b.disabled=false; b.textContent='저장하기'; }
    };
    var del=document.getElementById('btnPartnerDel');
    if(del) del.onclick=async function(){
      if(!confirm('상대방 정보를 지울까요?')) return;
      try{ await send({clear:true}); }catch(e){ alert('삭제 실패: '+e.message); }
    };
  })();
</script>

</div>

<style>
  .q-on{margin-top:8px;font-size:13px;color:#2f7a4f;background:#eef7f0;border-radius:8px;padding:9px 12px}
  .q-on b{color:#256b42}
  .q-off{margin-top:2px;font-size:13.5px;color:#8a6f3c;background:#fbf6ec;border:1px solid #ecdfc4;border-radius:8px;padding:11px 13px;line-height:1.65}
  .q-off b{color:#8a6f3c}
  .q-add{display:flex;gap:8px;margin-top:9px;align-items:flex-start}
  .q-add textarea{flex:1;border:1px solid #ddd2b8;border-radius:8px;padding:9px 11px;font-size:13.5px;font-family:inherit;resize:vertical}
  .q-add textarea:focus{outline:none;border-color:#B59A62}
  .q-add button{padding:10px 16px;background:#B59A62;color:#fff;border:0;border-radius:8px;font-weight:700;font-size:13px;cursor:pointer;white-space:nowrap}
</style>
<script>
  (function(){
    var btn = document.getElementById('qSave');
    if (!btn) return;
    btn.onclick = async function(){
      var v = document.getElementById('qAdd').value.trim();
      if (!v) { alert('질문을 입력해주세요.'); return; }
      btn.disabled = true; btn.textContent = '저장중';
      try {
        var r = await fetch('/leads/<%= lead.id %>/question', {
          method:'POST', headers:{'Content-Type':'application/json'},
          body: JSON.stringify({ question: v })
        });
        var d = await r.json();
        if (!d.ok) throw new Error(d.error || '실패');
        location.reload();
      } catch(e){
        alert('저장 실패: ' + e.message);
        btn.disabled = false; btn.textContent = '질문 저장';
      }
    };
  })();
</script>

<!-- 사주 원국 -->
<% if (saju) { %>
<div class="settings-block">
  <h2 class="section-h">사주 원국</h2>
  <div class="mini-chart">
    <table>
      <tr><th></th><th>생시</th><th>생일</th><th>생월</th><th>생년</th></tr>
      <% var cols=['hour','day','month','year']; %>
      <tr><th class="rh">천간</th>
        <% cols.forEach(function(c){ var s=saju.detail[c].stem; %>
          <td><% if(s){ %><span class="<%= EL[s.el] %>"><b><%= s.ko %></b><i><%= s.char %></i></span>
            <em class="<%= EL[s.el] %>"><%= s.yin?'-':'+' %><%= s.el %> · <%= s.god %></em>
          <% } else { %><span class="dim">미상</span><% } %></td>
        <% }); %></tr>
      <tr><th class="rh">지지</th>
        <% cols.forEach(function(c){ var b=saju.detail[c].branch; %>
          <td><% if(b){ %><span class="<%= EL[b.el] %>"><b><%= b.ko %></b><i><%= b.char %></i></span>
            <em class="<%= EL[b.el] %>"><%= b.yin?'-':'+' %><%= b.el %> · <%= b.god %></em>
          <% } else { %><span class="dim">미상</span><% } %></td>
        <% }); %></tr>
      <tr><th class="rh sm">지장간</th>
        <% cols.forEach(function(c){ var jj=saju.detail[c].jijanggan||[]; %>
          <td class="sm-cell"><% if(jj.length){ jj.forEach(function(g){ %><span class="<%= EL[g.el] %>"><%= g.ko %></span><% }); } else { %>—<% } %></td>
        <% }); %></tr>
      <tr><th class="rh sm">12운성</th>
        <% cols.forEach(function(c){ %>
          <td class="sm-cell"><%= saju.detail[c].unseong || '—' %></td>
        <% }); %></tr>
    </table>

    <% if (saju.daewoon && saju.daewoon.list.length) { %>
      <div class="dw-mini">
        <div class="dw-mini-t">대운 <span><%= saju.daewoon.forward ? '순행' : '역행' %></span></div>
        <div class="dw-mini-row">
          <% saju.daewoon.list.forEach(function(d){ %>
            <div class="dw-mini-item"><span><%= d.age %>세</span><b><%= d.ko %></b></div>
          <% }); %>
        </div>
      </div>
    <% } %>
    <% if (saju.elementWheel) { %>
      <%- include('../partials/element-wheel', {
            wheel: saju.elementWheel,
            dayMasterKo: saju.dayMasterKo,
            dayMasterElement: saju.dayMasterElement }) %>
    <% } %>
    <p class="chart-sum">
      강한 기운 <b><%= saju.strong.join(', ') %></b> &nbsp;·&nbsp; 부족한 기운 <b><%= saju.weak.join(', ') %></b>
    </p>
  </div>
</div>
<% } else { %>
  <div class="empty-box">생년월일 형식을 확인할 수 없어 사주를 계산하지 못했습니다.</div>
<% } %>

<!-- PDF 제작 -->
<div class="settings-block">
  <h2 class="section-h">사주 리포트 제작</h2>
  <% if (!hasKey) { %>
    <div class="warn-box">OpenAI API 키를 먼저 등록해주세요. <a href="/free-saju-settings">설정하러 가기 →</a></div>
  <% } else if (!saju) { %>
    <div class="warn-box">사주 계산이 안 되어 리포트를 만들 수 없습니다.</div>
  <% } else { %>
    <p class="block-desc">종류를 선택하면 AI가 이 분의 사주를 근거로 <b>60~80페이지</b> 리포트를 작성합니다.<br>표지 · 목차 · 만세력 · 본문 순서로 구성되며, 작성 후 <b>미리보기</b>에서 확인하고 PDF 저장 또는 이메일 발송할 수 있습니다.</p>
    <div class="type-grid" id="typeGrid">
      <% types.forEach(function(t){ %>
        <button type="button" class="type-btn" data-type="<%= t %>"><%= t %></button>
      <% }); %>
    </div>
    <button class="free-save-btn" id="btnMake" disabled>종류를 선택해주세요</button>
    <div class="prog" id="prog"></div>
  <% } %>
</div>

<!-- 제작된 리포트 -->
<div class="settings-block">
  <h2 class="section-h">제작된 리포트 <span class="count light"><%= pdfs.length %></span></h2>
  <% if (pdfs.length === 0) { %>
    <div class="empty-box">아직 제작한 리포트가 없습니다.</div>
  <% } else { %>
    <% if (pdfs.length > 1) { %>
      <button type="button" class="bundle-start" id="bdStart">☑ 묶어서 보내기</button>

      <div class="bundle-bar">
        <label class="bundle-all">
          <input type="checkbox" id="bdAll"> 전체 선택
        </label>
        <span class="bundle-cnt" id="bdCnt">0개 선택</span>
        <button type="button" class="btn btn-ghost" id="bdCancel">취소</button>
        <button type="button" class="btn btn-approve" id="bdSend" disabled>한 통에 보내기</button>
      </div>
    <% } %>

    <div class="tbl">
      <% pdfs.forEach(function(p){ %>
        <div class="tbl-row" id="pdf-<%= p.id %>">
          <% if (pdfs.length > 1) { %>
            <label class="bd-check">
              <input type="checkbox" class="bd-item" value="<%= p.id %>" data-type="<%= p.type %>">
            </label>
          <% } %>
          <div class="tbl-main">
            <div class="u-name"><%= p.type %>
              <% if (p.mail_sent) { %><span class="badge-sent">✓ 발송완료</span>
              <% } else { %><span class="badge-todo">미발송</span><% } %>
            </div>
            <div class="u-sub">
              제작 <%= fmt(p.created_at) %>
              <% if (p.mail_sent) { %> · 발송 <%= fmt(p.sent_at) %> → <%= p.sent_to %><% } %>
            </div>
          </div>
          <div class="tbl-actions">
            <a class="btn btn-ghost" href="/pdfs/<%= p.id %>/preview" target="_blank">미리보기</a>
            <button class="btn <%= p.mail_sent ? 'btn-ghost' : 'btn-approve' %>"
                    data-send="<%= p.id %>" data-email="<%= lead.email || '' %>">
              <%= p.mail_sent ? '다시 보내기' : '이메일 보내기' %>
            </button>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>

<script>
  var picked = null;
  var grid = document.getElementById('typeGrid');
  if (grid) {
    grid.addEventListener('click', function(e){
      var b = e.target.closest('.type-btn'); if(!b) return;
      grid.querySelectorAll('.type-btn').forEach(function(x){ x.classList.remove('on'); });
      b.classList.add('on');
      picked = b.dataset.type;
      var mk = document.getElementById('btnMake');
      mk.disabled = false;
      mk.textContent = picked + ' 리포트 만들기';
    });
  }

  /* ── 리포트 생성 ──
     접수만 하고 뒤에서 만든다. 창을 닫거나 다른 앱으로 넘어가도 계속 만들어지고,
     다시 들어오면 진행 중인 작업을 찾아 이어서 보여준다. */
  var LEAD_ID = '<%= lead.id %>';
  var btnMake = document.getElementById('btnMake');
  var pollTimer = null;

  function progEls() {
    return {
      box:  document.getElementById('prog'),
      msg:  document.getElementById('progMsg'),
      fill: document.getElementById('progFill'),
    };
  }

  function showRunning(job) {
    var prog = document.getElementById('prog');
    if (!prog) return;
    if (!document.getElementById('progMsg')) {
      prog.className = 'prog on';
      prog.innerHTML = '<b>리포트를 작성하고 있습니다.</b><br>' +
        '<span id="progMsg">준비 중...</span>' +
        '<div class="bar"><i id="progFill"></i></div>' +
        '<small>이 창을 닫아도 계속 만들어집니다. 다 되면 알림으로 알려드려요.</small>';
    }
    var e = progEls();
    var pct = job.total ? Math.round(job.done / job.total * 100) : 0;
    if (e.msg)  e.msg.textContent = '(' + job.done + '/' + (job.total || '?') + ') ' + (job.title || '');
    if (e.fill) e.fill.style.width = pct + '%';
    if (btnMake) { btnMake.disabled = true; btnMake.textContent = '작성 중...'; }
  }

  function showDone(job) {
    var prog = document.getElementById('prog');
    if (prog) {
      prog.className = 'prog ok';
      prog.innerHTML = '완성됐습니다 (' + job.done + '개 챕터). ' +
        '<a href="/pdfs/' + job.pdf_id + '/preview" style="text-decoration:underline">미리보기 열기</a>';
    }
    if (btnMake) { btnMake.disabled = false; btnMake.textContent = (picked || '') + ' 리포트 만들기'; }
  }

  function showError(job) {
    var prog = document.getElementById('prog');
    if (prog) {
      prog.className = 'prog err';
      prog.textContent = '실패: ' + (job.error || '알 수 없는 오류');
    }
    if (btnMake) { btnMake.disabled = false; btnMake.textContent = (picked || '') + ' 리포트 만들기'; }
  }

  var lastSeenJob = null;

  async function pollJob(opts) {
    try {
      var r = await fetch('/leads/' + LEAD_ID + '/pdf/job');
      var d = await r.json();
      var job = d && d.job;
      if (!job) return;

      if (job.status === 'running') {
        showRunning(job);
        lastSeenJob = job.id;
        if (!pollTimer) pollTimer = setInterval(function(){ pollJob({}); }, 3000);
        return;
      }

      if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }

      // 화면을 보고 있던 작업이 끝났을 때만 미리보기로 넘긴다.
      // (들어오자마자 옛 작업 때문에 튕기지 않도록)
      if (job.status === 'done') {
        showDone(job);
        if (opts && opts.jump && lastSeenJob === job.id) {
          setTimeout(function(){ location.href = '/pdfs/' + job.pdf_id + '/preview'; }, 900);
        }
      } else if (job.status === 'error') {
        if (lastSeenJob === job.id || (opts && opts.showOld)) showError(job);
      }
    } catch (e) { /* 잠시 끊겨도 다음 차례에 다시 물어본다 */ }
  }

  if (btnMake) {
    btnMake.onclick = async function(){
      if (!picked) return;
      btnMake.disabled = true;
      btnMake.textContent = '접수 중...';
      try {
        var r = await fetch('/leads/' + LEAD_ID + '/pdf/start', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: picked })
        });
        var d = await r.json();
        if (!d.ok) throw new Error(d.error || '시작하지 못했습니다.');
        lastSeenJob = d.jobId;
        showRunning({ done: 0, total: 0, title: '준비 중' });
        if (pollTimer) clearInterval(pollTimer);
        pollTimer = setInterval(function(){ pollJob({ jump: true }); }, 3000);
      } catch (e) {
        showError({ error: e.message });
      }
    };
  }

  // 화면에 들어오거나 다시 돌아왔을 때 진행 중인 작업이 있으면 이어서 보여준다
  pollJob({});
  document.addEventListener('visibilitychange', function(){
    if (!document.hidden) pollJob({ jump: true });
  });

  document.querySelectorAll('[data-send]').forEach(function(btn){
    btn.onclick = async function(){
      var id = btn.dataset.send;
      var email = btn.dataset.email;
      if(!email){ alert('이 신청자의 이메일이 없습니다.'); return; }
      if(!confirm(email + ' 로 보낼까요?')) return;
      var old = btn.textContent;
      btn.disabled = true; btn.textContent = '보내는 중...';
      try {
        var r = await fetch('/pdfs/'+id+'/send', {
          method:'POST', headers:{'Content-Type':'application/json'},
          body: JSON.stringify({ email: email })
        });
        var d = await r.json();
        if(!d.ok) throw new Error(d.error || '실패');
        alert('발송 완료: ' + d.to);
        location.reload();
      } catch(e) {
        alert('발송 실패: ' + e.message);
        btn.disabled = false; btn.textContent = old;
      }
    };
  });
</script>

<script>
/* 묶어서 보내기 */
(function(){
  var all = document.getElementById('bdAll');
  var btn = document.getElementById('bdSend');
  var cnt = document.getElementById('bdCnt');
  var start = document.getElementById('bdStart');
  var cancel = document.getElementById('bdCancel');
  if (!btn || !start) return;

  start.addEventListener('click', function(){
    document.body.classList.add('bundling');
  });
  cancel.addEventListener('click', function(){
    document.body.classList.remove('bundling');
    items().forEach(function(x){ x.checked = false; });
    sync();
  });

  var EMAIL = <%- JSON.stringify(lead.email || '') %>;
  var LEAD_ID = <%= lead.id %>;

  function items(){ return Array.prototype.slice.call(document.querySelectorAll('.bd-item')); }
  function picked(){ return items().filter(function(x){ return x.checked; }); }

  function sync(){
    var n = picked().length;
    cnt.textContent = n + '개 선택';
    btn.disabled = n < 1;
    all.checked = n > 0 && n === items().length;
  }

  all.addEventListener('change', function(){
    items().forEach(function(x){ x.checked = all.checked; });
    sync();
  });
  items().forEach(function(x){ x.addEventListener('change', sync); });

  btn.addEventListener('click', async function(){
    var sel = picked();
    if (!sel.length) return;
    if (!EMAIL) { alert('이 신청자의 이메일이 없습니다.'); return; }

    var names = sel.map(function(x){ return x.dataset.type; }).join(', ');
    if (!confirm(EMAIL + ' 로 아래 리포트를 한 통에 담아 보낼까요?\n\n' + names)) return;

    btn.disabled = true;
    btn.textContent = '보내는 중...';
    try {
      var r = await fetch('/leads/' + LEAD_ID + '/send-bundle', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ pdfIds: sel.map(function(x){ return Number(x.value); }) })
      });
      var d = await r.json();
      if (!d.ok) throw new Error(d.error || '실패');
      alert('발송 완료: ' + d.to + '\n리포트 ' + d.count + '개');
      location.reload();
    } catch (e) {
      alert('발송 실패: ' + e.message);
      btn.disabled = false;
      btn.textContent = '묶어서 보내기';
    }
  });

  sync();
})();
</script>


