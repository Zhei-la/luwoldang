<script>
  (function(){
    var btn = document.getElementById('btnEditLead');
    var view = document.getElementById('leadView');
    var edit = document.getElementById('leadEdit');
    if (!btn || !view || !edit) return;

    function show(editing){
      view.style.display = editing ? 'none' : '';
      edit.style.display = editing ? '' : 'none';
      btn.textContent = editing ? '수정 닫기' : '정보 수정';
    }
    btn.onclick = function(){ show(edit.style.display === 'none'); };
    document.getElementById('btnCancelLead').onclick = function(){ show(false); };

    document.getElementById('btnSaveLead').onclick = async function(){
      var v = function(id){ var e = document.getElementById(id); return e ? e.value.trim() : ''; };
      var name = v('edName');
      if (!name) { alert('이름을 입력해주세요.'); return; }
      var email = v('edEmail');
      if (email && !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) {
        alert('이메일 형식을 확인해주세요.'); return;
      }
      var b = this;
      b.disabled = true; b.textContent = '저장중...';
      try {
        var r = await fetch('/leads/<%= lead.id %>/edit', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: name, gender: v('edGender'), birth: v('edBirth'), calendar: v('edCal'),
            hour: v('edHour'), region: v('edRegion'), email: email, phone: v('edPhone')
          })
        });
        var d = await r.json();
        if (!d.ok) throw new Error(d.error || '실패');
        location.reload();
      } catch(e) {
        alert('저장 실패: ' + e.message);
        b.disabled = false; b.textContent = '저장하기';
      }
    };
  })();
</script>

