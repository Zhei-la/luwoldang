<%- include('../partials/dash-top', { user: user, active: active, title: '기본 표지 관리' }) %>

<div class="settings-block">
  <h2 class="section-h">표지 세트 관리</h2>
  <p class="block-desc">
    <b>세트</b>는 8종 리포트 표지를 한 묶음으로 관리합니다.
    교육생이 세트를 고르면 8종이 모두 그 디자인으로 나갑니다.<br>
    기본 세트(한지·매화·수묵·호랑이)는 시스템에 내장돼 있고, 여기서 <b>새 세트</b>를 추가할 수 있습니다.
  </p>

  <!-- 새 세트 만들기 -->
  <div class="ac-form" style="max-width:460px">
    <label class="ac-row">
      <span>세트 키 <em>(영문·숫자, 예: spring2026)</em></span>
      <input type="text" id="setKey" placeholder="spring2026">
    </label>
    <label class="ac-row">
      <span>세트 이름</span>
      <input type="text" id="setName" placeholder="예: 봄 에디션">
    </label>
    <button type="button" class="ac-submit" onclick="createSet()">새 세트 만들기</button>
  </div>

  <!-- 등록된 커스텀 세트 -->
  <% if (customSets && customSets.length) { %>
    <div style="margin-top:20px">
      <% customSets.forEach(function (s) { %>
        <div class="set-manage">
          <div class="set-manage-head">
            <b><%= s.name %></b> <span class="set-key-badge"><%= s.set_key %></span>
            <span class="set-cnt"><%= s.cnt %>/8종</span>
            <button type="button" class="set-del" onclick="deleteSet('<%= s.set_key %>')">세트 삭제</button>
          </div>
          <div class="set-manage-items">
            <% types.forEach(function (t) { %>
              <label class="set-item-up">
                <span><%= t %></span>
                <input type="file" accept="image/*" hidden onchange="addSetItem(this, '<%= s.set_key %>', '<%= t %>')">
                <em>올리기</em>
              </label>
            <% }); %>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>

<div class="settings-block">
  <h2 class="section-h">낱개 기본 표지 (선택)</h2>
  <p class="block-desc">
    세트와 별개로, 특정 종류 하나의 기본 표지만 바꾸고 싶을 때 씁니다.
  </p>
</div>

<!-- 새 표지 올리기 -->
<div class="settings-block">
  <h3 class="section-h" style="font-size:15px">새 기본 표지 추가</h3>
  <div class="ac-form">
    <label class="ac-row">
      <span>리포트 종류</span>
      <select id="acType">
        <% types.forEach(function (t) { %><option value="<%= t %>"><%= t %></option><% }); %>
      </select>
    </label>
    <label class="ac-row">
      <span>표지 이름 <em>(관리용)</em></span>
      <input type="text" id="acName" placeholder="예: 봄 에디션 표지">
    </label>
    <label class="ac-row">
      <span>브랜드명 얹기</span>
      <select id="acStyle">
        <option value="plain">얹지 않음 (표지에 이미 이름이 있음)</option>
        <option value="circle">비어있는 자리에 얹기</option>
        <option value="ink">진한 배경 위에 얹기</option>
      </select>
    </label>
    <label class="ac-row">
      <span>이미지 파일</span>
      <input type="file" id="acFile" accept="image/*">
    </label>
    <button type="button" class="ac-submit" onclick="addPreset()">기본 표지로 추가</button>
  </div>
</div>

<!-- 등록된 표지 목록 -->
<div class="settings-block">
  <h3 class="section-h" style="font-size:15px">등록된 기본 표지</h3>
  <% if (!presets.length) { %>
    <div class="empty-box">아직 등록된 기본 표지가 없습니다. 위에서 추가해보세요.</div>
  <% } else { %>
    <div class="ac-grid">
      <% presets.forEach(function (p) { %>
        <div class="ac-card">
          <div class="ac-thumb" style="background-image:url('/admin/covers/img/<%= p.id %>')"></div>
          <div class="ac-meta">
            <div class="ac-type"><%= p.type %></div>
            <% if (p.name) { %><div class="ac-nm"><%= p.name %></div><% } %>
          </div>
          <button type="button" class="ac-del" onclick="delPreset('<%= p.id %>')">삭제</button>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>

<div class="toast" id="toast"></div>

<style>
  /* 세트 관리 */
  .set-manage { border:1px solid #e6e0d2; border-radius:10px; padding:14px; margin-bottom:12px; background:#fff; }
  .set-manage-head { display:flex; align-items:center; gap:10px; margin-bottom:12px; flex-wrap:wrap; }
  .set-key-badge { font-size:11px; color:#8a7f66; background:#f3efe4; padding:2px 8px; border-radius:10px; }
  .set-cnt { font-size:12px; color:#B59A62; font-weight:700; }
  .set-del { margin-left:auto; padding:5px 12px; border:1px solid #eab; background:#fff; color:#b0392c;
    border-radius:6px; font-size:12px; cursor:pointer; font-family:inherit; }
  .set-manage-items { display:grid; grid-template-columns:repeat(auto-fill,minmax(110px,1fr)); gap:8px; }
  .set-item-up { display:flex; flex-direction:column; align-items:center; gap:4px; padding:10px 4px;
    border:1px dashed #d8cfb8; border-radius:8px; cursor:pointer; }
  .set-item-up span { font-size:12px; color:#3a3527; font-weight:600; }
  .set-item-up em { font-style:normal; font-size:11px; color:#B59A62; font-weight:700; }
  .set-item-up:hover { background:#fbf6ec; }

</style>
<style>
  .ac-form { display:flex; flex-direction:column; gap:12px; max-width:460px; }
  .ac-row { display:flex; flex-direction:column; gap:5px; }
  .ac-row span { font-size:13px; font-weight:700; color:#3a3527; }
  .ac-row span em { font-style:normal; color:#b3ad9c; font-weight:500; }
  .ac-row select, .ac-row input[type=text] { padding:9px 11px; border:1px solid #d8cfb8; border-radius:7px;
    font-size:14px; font-family:inherit; }
  .ac-submit { margin-top:4px; padding:11px; border:0; border-radius:8px; background:#B59A62; color:#241a06;
    font-weight:800; font-size:14px; cursor:pointer; font-family:inherit; }
  .ac-submit:hover { opacity:.9; }
  .ac-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(140px,1fr)); gap:14px; }
  .ac-card { border:1px solid #e6e0d2; border-radius:10px; overflow:hidden; background:#fff; }
  .ac-thumb { aspect-ratio:1/1.414; background:#f3efe4 center/cover no-repeat; }
  .ac-meta { padding:8px 10px 4px; }
  .ac-type { font-weight:700; font-size:13px; color:#3a3527; }
  .ac-nm { font-size:11.5px; color:#8a7f66; margin-top:2px; }
  .ac-del { width:100%; padding:7px; border:0; border-top:1px solid #eee; background:#fff; color:#b0392c;
    font-size:12px; font-weight:700; cursor:pointer; font-family:inherit; }
  .ac-del:hover { background:#fdf0ef; }
  .toast { position:fixed; bottom:24px; left:50%; transform:translateX(-50%) translateY(10px); opacity:0;
    background:#2f9e5e; color:#fff; padding:10px 20px; border-radius:8px; font-size:13px; font-weight:700;
    z-index:99; transition:.25s; pointer-events:none; }
  .toast.on { opacity:1; transform:translateX(-50%); }
</style>

<script>
  function toast(msg, bad) {
    var t = document.getElementById('toast');
    t.textContent = msg; t.style.background = bad ? '#c0392b' : '#2f9e5e';
    t.classList.add('on'); setTimeout(function () { t.classList.remove('on'); }, 2000);
  }

  async function createSet() {
    var key = document.getElementById('setKey').value.trim();
    var name = document.getElementById('setName').value.trim();
    if (!key || !name) { toast('세트 키와 이름을 입력하세요.', true); return; }
    try {
      var r = await fetch('/admin/covers/set/create', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: key, name: name })
      });
      var d = await r.json();
      if (!d.ok) throw new Error(d.error || '실패');
      toast('세트를 만들었습니다');
      setTimeout(function () { location.reload(); }, 800);
    } catch (e) { toast(e.message, true); }
  }

  function addSetItem(input, setKey, type) {
    var file = input.files && input.files[0];
    input.value = '';
    if (!file) return;
    if (file.size > 3 * 1024 * 1024) { toast('이미지가 너무 큽니다. 3MB 이하로.', true); return; }
    var reader = new FileReader();
    reader.onload = async function () {
      toast(type + ' 올리는 중...');
      try {
        var r = await fetch('/admin/covers/set/add-item', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ setKey: setKey, type: type, img: reader.result, style: 'plain' })
        });
        var d = await r.json();
        if (!d.ok) throw new Error(d.error || '실패');
        toast(type + ' 표지를 올렸습니다');
        setTimeout(function () { location.reload(); }, 800);
      } catch (e) { toast(e.message, true); }
    };
    reader.readAsDataURL(file);
  }

  async function deleteSet(key) {
    if (!confirm('이 세트를 삭제할까요? (교육생이 이 세트를 쓰고 있으면 기본 표지로 돌아갑니다)')) return;
    try {
      var r = await fetch('/admin/covers/set/delete/' + key, { method: 'POST' });
      var d = await r.json();
      if (!d.ok) throw new Error(d.error || '실패');
      toast('세트를 삭제했습니다');
      setTimeout(function () { location.reload(); }, 700);
    } catch (e) { toast(e.message, true); }
  }

  function addPreset() {
    var type = document.getElementById('acType').value;
    var name = document.getElementById('acName').value;
    var style = document.getElementById('acStyle').value;
    var file = document.getElementById('acFile').files[0];
    if (!file) { toast('이미지를 골라주세요.', true); return; }
    if (file.size > 3 * 1024 * 1024) { toast('이미지가 너무 큽니다. 3MB 이하로.', true); return; }

    var reader = new FileReader();
    reader.onload = async function () {
      toast('올리는 중...');
      try {
        var r = await fetch('/admin/covers/add', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: type, name: name, img: reader.result, style: style })
        });
        var d = await r.json();
        if (!d.ok) throw new Error(d.error || '실패');
        toast('기본 표지를 추가했습니다');
        setTimeout(function () { location.reload(); }, 900);
      } catch (e) { toast(e.message, true); }
    };
    reader.readAsDataURL(file);
  }

  async function delPreset(id) {
    if (!confirm('이 기본 표지를 삭제할까요?')) return;
    try {
      var r = await fetch('/admin/covers/delete/' + id, { method: 'POST' });
      var d = await r.json();
      if (!d.ok) throw new Error(d.error || '실패');
      toast('삭제했습니다');
      setTimeout(function () { location.reload(); }, 700);
    } catch (e) { toast(e.message, true); }
  }
</script>
