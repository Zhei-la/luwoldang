<%- include('../partials/dash-top', { user: user, active: active, title: '계정 전환' }) %>

<div class="settings-block">
  <h2 class="section-h">계정 전환</h2>
  <p class="block-desc">
    승인된 회원의 계정으로 들어가 <b>그분이 보는 화면 그대로</b> 확인할 수 있습니다.
    설정이 왜 그렇게 나오는지, 리포트가 왜 안 만들어지는지 물어보실 때 직접 보시면 빠릅니다.<br>
    전환하면 화면 맨 위에 <b>[관리자로 돌아가기]</b> 띠가 생기고, 언제든 눌러서 원래 계정으로 복귀합니다.
  </p>

  <p class="hint" style="margin-bottom:16px">
    ⚠️ 전환한 동안 하는 모든 작업은 <b>그 회원이 한 것으로 기록됩니다.</b>
    리포트를 만들면 그분의 OpenAI 키로 요금이 나가고, 신청자 정보도 그분 것이 보입니다.
    확인할 것만 보고 바로 돌아와 주세요.
  </p>

  <form method="get" action="/admin/accounts" class="acc-search">
    <input type="text" name="q" value="<%= q || '' %>" placeholder="이름 · 이메일 · 상호명 · 메모로 찾기">
    <button type="submit" class="btn btn-ghost">찾기</button>
    <% if (q) { %><a class="btn btn-ghost" href="/admin/accounts">전체 보기</a><% } %>
  </form>

  <% if (!accounts.length) { %>
    <p class="hint" style="text-align:center;padding:28px 10px">
      <% if (q) { %>
        "<%= q %>" 로 찾은 회원이 없습니다.
      <% } else { %>
        전환할 수 있는 승인 회원이 아직 없습니다.
      <% } %>
    </p>
  <% } else { %>
    <p class="hint" style="margin:14px 0 10px">회원 <%= accounts.length %>명</p>

    <% accounts.forEach(function (u) { %>
      <div class="acc-row">
        <div class="acc-main">
          <span class="acc-name">
            <%= u.name %>
            <% if (u.role === 'admin') { %><span class="acc-tag">관리자</span><% } %>
          </span>
          <span class="acc-sub">
            <%= u.site_name ? u.site_name + ' · ' : '' %><%= u.email || '이메일 없음' %>
          </span>
          <% if (u.admin_note) { %>
            <span class="acc-note">📝 <%= u.admin_note %></span>
          <% } %>
        </div>
        <a class="btn btn-ghost as-btn" href="/auth/as/<%= u.id %>"
           onclick="return confirm('<%= u.name %>님 계정으로 전환할까요?\n\n전환한 동안의 작업은 그분이 한 것으로 남습니다.\n상단의 [관리자로 돌아가기] 로 언제든 복귀할 수 있습니다.');">
          이 계정으로 보기
        </a>
      </div>
    <% }); %>
  <% } %>
</div>

<style>
  .acc-search { display: flex; gap: 8px; flex-wrap: wrap; }
  .acc-search input {
    flex: 1; min-width: 180px; padding: 10px 12px;
    border: 1px solid var(--line, #e4e0d6); border-radius: 8px; font-size: 14px; font-family: inherit;
  }
  .acc-row {
    display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
    padding: 13px 4px; border-bottom: 1px solid var(--line, #e4e0d6);
  }
  .acc-main { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 3px; }
  .acc-name { font-size: 14.5px; font-weight: 700; }
  .acc-tag {
    margin-left: 6px; padding: 2px 7px; border-radius: 99px;
    background: rgba(181,154,98,.16); color: #8a6a2f; font-size: 11px; font-weight: 700;
  }
  .acc-sub { font-size: 12.5px; color: #8a8574; word-break: break-all; }
  .acc-note { font-size: 12px; color: #8a8574; }
  .acc-row .as-btn { flex: none; }
  @media (max-width: 560px) {
    .acc-row .as-btn { width: 100%; text-align: center; }
  }
</style>

<%- include('../partials/dash-bottom') %>
