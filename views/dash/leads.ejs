<%- include('../partials/dash-top', { user: user, active: active, title: '상담 신청 내역' }) %>

<%
  function fmt(d){ try { return new Date(d).toLocaleString('ko-KR',{month:'numeric',day:'numeric',hour:'2-digit',minute:'2-digit'}); } catch(e){ return '-'; } }
%>

<h2 class="section-h">상담 신청 <span class="count light"><%= leads.length %></span></h2>

<% if (leads.length === 0) { %>
  <div class="empty-box">아직 신청 내역이 없습니다.<br>랜딩 페이지 링크를 공유해보세요.</div>
<% } else { %>
  <div class="tbl">
    <% leads.forEach(function(l){ %>
      <div class="tbl-row lead-row">
        <div class="tbl-main">
          <div class="u-name">
            <%= l.name %>
            <span class="u-role"><%= l.gender || '-' %></span>
            <% if (l.product) { %><span class="u-role"><%= l.product %></span><% } %>
          </div>
          <div class="u-sub">
            <%= l.birth || '-' %> <%= l.calendar || '' %> <%= l.hour && l.hour !== '모름 / 선택 안함' ? l.hour : '(시간모름)' %>
            <% if (l.region) { %> · <%= l.region %><% } %>
          </div>
          <div class="u-sub"><%= l.phone %><% if (l.email) { %> · <%= l.email %><% } %></div>
          <% if (l.memo) { %><div class="lead-memo"><%= l.memo %></div><% } %>
        </div>
        <div class="tbl-actions">
          <span class="lead-time"><%= fmt(l.created_at) %></span>
        </div>
      </div>
    <% }); %>
  </div>
<% } %>

<%- include('../partials/dash-bottom') %>
