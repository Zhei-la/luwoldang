<%- include('../partials/dash-top', { user: user, active: active, title: '사주 신청자' }) %>

<%
  function fmt(d){ try { return new Date(d).toLocaleString('ko-KR',{timeZone:'Asia/Seoul',month:'numeric',day:'numeric',hour:'2-digit',minute:'2-digit'}); } catch(e){ return '-'; } }
  var tabs = [['all','전체'],['상담신청','상담 신청'],['무료사주','무료사주'],['미발송','미발송'],['발송완료','발송완료']];
%>

<div class="filters">
  <% tabs.forEach(function(t){ %>
    <a href="/leads?f=<%= t[0] %>" class="ftab <%= filter === t[0] ? 'on' : '' %>">
      <%= t[1] %><span><%= counts[t[0]] %></span>
    </a>
  <% }); %>
</div>

<% if (leads.length === 0) { %>
  <div class="empty-box">
    <% if (filter === 'all') { %>
      아직 신청 내역이 없습니다.<br>내 웹사이트 링크를 공유해보세요.
    <% } else { %>
      해당하는 내역이 없습니다.
    <% } %>
  </div>
<% } else { %>
  <div class="tbl">
    <% leads.forEach(function(l){ %>
      <a class="tbl-row lead-row" href="/leads/<%= l.id %>">
        <div class="tbl-main">
          <div class="u-name">
            <%= l.name %>
            <span class="u-role"><%= l.gender || '-' %></span>
            <% if (l.source === '무료사주') { %>
              <span class="src free">무료사주</span>
            <% } else { %>
              <span class="src paid">상담 신청</span>
            <% } %>
          </div>
          <div class="u-sub">
            <%= l.birth || '-' %> <%= l.calendar || '' %>
            <%= (l.hour && !/모름/.test(l.hour)) ? l.hour : '(시간모름)' %>
            <% if (l.region) { %> · <%= l.region %><% } %>
          </div>
          <div class="u-sub">
            <% if (l.email) { %><%= l.email %><% } %>
            <% if (l.phone) { %><%= l.email ? ' · ' : '' %><%= l.phone %><% } %>
            <% if (l.product) { %> · <b><%= l.product %></b><% } %>
          </div>
          <% if (l.memo) { %><div class="lead-memo"><%= l.memo %></div><% } %>
        </div>
        <div class="tbl-actions lead-right">
          <% if (l.mail_sent) { %>
            <span class="badge-sent">✓ 발송완료</span>
            <span class="lead-time"><%= l.pdf_type %></span>
          <% } else if (l.pdf_id) { %>
            <span class="badge-made">PDF 제작됨</span>
            <span class="lead-time">미발송</span>
          <% } else if (l.source === '무료사주') { %>
            <span class="badge-free">무료사주 발송됨</span>
          <% } else { %>
            <span class="badge-todo">제작 대기</span>
          <% } %>
          <span class="lead-time"><%= fmt(l.created_at) %></span>
        </div>
      </a>
    <% }); %>
  </div>
<% } %>

<%- include('../partials/dash-bottom') %>
