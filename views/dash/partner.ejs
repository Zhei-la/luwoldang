<%- include('../partials/dash-top', { user: user, active: active, title: '모집하기' }) %>

<style>
  .pt-block { background:#fff; border:1px solid #e6e0d2; border-radius:14px; padding:22px; margin-bottom:18px; }
  .pt-block h2 { font-size:18px; font-weight:800; color:#33301f; margin-bottom:12px; }
  .pt-desc { font-size:14px; color:#6a6250; margin-bottom:16px; line-height:1.7; }
  .link-row { display:flex; gap:8px; }
  .link-row input { flex:1; padding:12px 14px; border:1px solid #ddd2b8; border-radius:10px; font-size:14px; background:#faf7f0; color:#4a3d28; }
  .link-row button { padding:12px 18px; background:#B59A62; color:#fff; border:0; border-radius:10px; font-weight:800; font-size:14px; cursor:pointer; white-space:nowrap; }
  .link-row button:active { opacity:.85; }
  .stat-cards { display:grid; grid-template-columns:repeat(auto-fill,minmax(130px,1fr)); gap:12px; }
  .stat-card { background:#faf8f2; border:1px solid #ece6d8; border-radius:12px; padding:16px 14px; text-align:center; }
  .stat-card.accent { background:#fbf6ec; border-color:#e6d9b8; }
  .stat-label { font-size:12.5px; color:#8a8372; margin-bottom:8px; }
  .stat-num { font-size:26px; font-weight:800; color:#3a3527; }
  .kakao-note { font-size:13px; color:#8a6f3c; background:#fbf6ec; border:1px solid #ecdfc4; border-radius:10px; padding:12px 14px; margin-top:12px; }
  .toast { position:fixed; bottom:24px; left:50%; transform:translateX(-50%) translateY(10px); opacity:0; background:#333; color:#fff; padding:12px 20px; border-radius:24px; font-size:14px; z-index:99; transition:.25s; pointer-events:none; }
  .toast.show { opacity:1; transform:translateX(-50%) translateY(0); }
</style>

<div class="pt-block">
  <h2>내 모집 링크</h2>
  <p class="pt-desc">아래 링크를 공유하세요. 이 링크로 들어온 분이 카카오톡 상담 버튼을 누르면 <b>내 카톡</b>으로 연결됩니다.</p>
  <div class="link-row">
    <input type="text" id="myLink" value="<%= link %>" readonly onclick="this.select()">
    <button onclick="copyLink()">복사</button>
  </div>
  <% if (!kakao) { %>
    <div class="kakao-note">아직 카카오톡 링크가 지정되지 않았습니다. 관리자에게 문의해주세요.</div>
  <% } %>
</div>

<div class="pt-block">
  <h2>모집 현황</h2>
  <div class="stat-cards">
    <div class="stat-card"><div class="stat-label">오늘 방문</div><div class="stat-num"><%= stats.visitToday %></div></div>
    <div class="stat-card"><div class="stat-label">전체 방문</div><div class="stat-num"><%= stats.visitTotal %></div></div>
    <div class="stat-card accent"><div class="stat-label">오늘 카톡 클릭</div><div class="stat-num"><%= stats.kakaoToday %></div></div>
    <div class="stat-card accent"><div class="stat-label">전체 카톡 클릭</div><div class="stat-num"><%= stats.kakaoTotal %></div></div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
  function toast(m){ var t=document.getElementById('toast'); t.textContent=m; t.classList.add('show'); setTimeout(function(){t.classList.remove('show');},1600); }
  function copyLink(){
    var el = document.getElementById('myLink');
    el.select();
    navigator.clipboard.writeText(el.value).then(function(){ toast('링크를 복사했습니다'); })
      .catch(function(){ document.execCommand('copy'); toast('링크를 복사했습니다'); });
  }
</script>

<%- include('../partials/dash-bottom') %>
