<%- include('../partials/dash-top', { user: user, active: active, title: '회원 승인 · 관리' }) %>

<%
  function fmtDate(d) {
    if (!d) return '-';
    try { return new Date(d).toLocaleDateString('ko-KR',{timeZone:'Asia/Seoul'}); } catch (e) { return '-'; }
  }
  function roleLabel(r) { return r === 'admin' ? '관리자' : '교육생'; }
%>

<!-- 승인 대기 -->
<h2 class="section-h">승인 대기 <% if (pending.length) { %><span class="count"><%= pending.length %></span><% } %></h2>
<% if (pending.length === 0) { %>
  <div class="empty-box">승인 대기 중인 회원이 없습니다.</div>
<% } else { %>
  <div class="tbl">
    <% pending.forEach(function (u) { %>
      <div class="tbl-row">
        <div class="tbl-main">
          <div class="u-name"><%= u.name %> <span class="u-role"><%= roleLabel(u.role) %></span></div>
          <div class="u-sub">가입일 <%= fmtDate(u.created_at) %><% if (u.account_email) { %> · <%= u.account_email %><% } %></div>
        </div>
        <div class="tbl-actions">
          <form method="post" action="/admin/approve/<%= u.id %>">
            <button class="btn btn-approve" type="submit">승인</button>
          </form>
          <form method="post" action="/admin/reject/<%= u.id %>">
            <button class="btn btn-reject" type="submit">거절</button>
          </form>
        </div>
      </div>
    <% }); %>
  </div>
<% } %>

<!-- 승인 완료 -->
<h2 class="section-h" style="margin-top:36px;">승인 완료 <span class="count light"><%= approved.length %></span></h2>
<% if (approved.length === 0) { %>
  <div class="empty-box">승인된 회원이 없습니다.</div>
<% } else { %>
  <div class="tbl">
    <% approved.forEach(function (u) { %>
      <div class="tbl-row">
        <div class="tbl-main">
          <div class="u-name"><%= u.name %> <span class="u-role <%= u.role === 'admin' ? 'admin' : '' %>"><%= roleLabel(u.role) %></span></div>
          <div class="u-sub">승인일 <%= fmtDate(u.approved_at) %> · 링크코드 <%= u.slug %></div>
        </div>
        <div class="tbl-actions">
          <% if (String(u.id) === String(user.id)) { %>
            <span class="me-tag">나</span>
          <% } else { %>
            <% if (u.role === 'admin') { %>
              <form method="post" action="/admin/role/<%= u.id %>" onsubmit="return confirm('<%= u.name %>님의 관리자 권한을 내리고 교육생으로 바꿀까요?');">
                <input type="hidden" name="role" value="trainee">
                <button class="btn btn-ghost" type="submit">교육생으로</button>
              </form>
            <% } else { %>
              <form method="post" action="/admin/role/<%= u.id %>" onsubmit="return confirm('<%= u.name %>님을 관리자로 올릴까요?\n\n관리자는 모든 교육생의 기록과 회원 승인 권한을 갖습니다.');">
                <input type="hidden" name="role" value="admin">
                <button class="btn btn-ghost" type="submit">관리자로</button>
              </form>
            <% } %>
            <form method="post" action="/admin/revoke/<%= u.id %>" onsubmit="return confirm('이 회원을 다시 승인 대기 상태로 되돌릴까요?');">
              <button class="btn btn-ghost" type="submit">승인 해제</button>
            </form>
          <% } %>
        </div>
      </div>
      <!-- 모집 파트너 -->
      <div class="partner-row" data-id="<%= u.id %>">
        <label class="partner-toggle">
          <input type="checkbox" <%= u.partner_on ? 'checked' : '' %> onchange="togglePartner(<%= u.id %>, this)">
          <span>모집 파트너</span>
        </label>
        <div class="partner-detail" style="<%= u.partner_on ? '' : 'display:none' %>">
          <input type="text" class="partner-kakao" placeholder="이 파트너 전용 카톡 링크" value="<%= u.partner_kakao || '' %>">
          <button type="button" onclick="saveKakao(<%= u.id %>, this)">저장</button>
          <% if (u.partner_slug) { %><a class="partner-link" href="/p/<%= u.partner_slug %>" target="_blank">모집페이지 ↗</a><% } %>
        </div>
      </div>
    <% }); %>
  </div>
<% } %>

<style>
  .partner-row { background:#faf8f2; border:1px solid #ece6d8; border-radius:10px; padding:12px 16px; margin:-6px 0 14px; }
  .partner-toggle { display:flex; align-items:center; gap:8px; font-size:14px; font-weight:700; color:#8a6f3c; cursor:pointer; }
  .partner-toggle input { width:18px; height:18px; }
  .partner-detail { display:flex; gap:8px; align-items:center; margin-top:10px; flex-wrap:wrap; }
  .partner-detail .partner-kakao { flex:1; min-width:200px; padding:9px 12px; border:1px solid #ddd2b8; border-radius:8px; font-size:13px; }
  .partner-detail button { padding:9px 16px; background:#B59A62; color:#fff; border:0; border-radius:8px; font-weight:700; font-size:13px; cursor:pointer; }
  .partner-link { font-size:13px; color:#8a6f3c; font-weight:700; text-decoration:none; white-space:nowrap; }
</style>

<script>
  async function togglePartner(id, box){
    try {
      var r = await fetch('/admin/partner/' + id + '/toggle', { method:'POST' });
      var d = await r.json();
      if (!d.ok) throw new Error(d.error || '실패');
      var row = document.querySelector('.partner-row[data-id="' + id + '"]');
      row.querySelector('.partner-detail').style.display = d.partner_on ? '' : 'none';
      if (d.partner_on) setTimeout(function(){ location.reload(); }, 400);
    } catch(e){ alert('실패: ' + e.message); box.checked = !box.checked; }
  }
  async function saveKakao(id, btn){
    var row = document.querySelector('.partner-row[data-id="' + id + '"]');
    var kakao = row.querySelector('.partner-kakao').value.trim();
    btn.disabled = true; btn.textContent = '저장중';
    try {
      var r = await fetch('/admin/partner/' + id + '/kakao', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ kakao: kakao })
      });
      var d = await r.json();
      if (!d.ok) throw new Error(d.error || '실패');
      btn.textContent = '저장됨';
      setTimeout(function(){ btn.textContent='저장'; btn.disabled=false; }, 1200);
    } catch(e){ alert('실패: ' + e.message); btn.textContent='저장'; btn.disabled=false; }
  }
</script>

<!-- 거절됨 -->
<% if (rejected.length > 0) { %>
  <h2 class="section-h" style="margin-top:36px;">거절됨 <span class="count light"><%= rejected.length %></span></h2>
  <div class="tbl">
    <% rejected.forEach(function (u) { %>
      <div class="tbl-row">
        <div class="tbl-main">
          <div class="u-name"><%= u.name %></div>
          <div class="u-sub">가입일 <%= fmtDate(u.created_at) %></div>
        </div>
        <div class="tbl-actions">
          <form method="post" action="/admin/approve/<%= u.id %>">
            <button class="btn btn-approve" type="submit">승인으로 변경</button>
          </form>
        </div>
      </div>
    <% }); %>
  </div>
<% } %>

<%- include('../partials/dash-bottom') %>
