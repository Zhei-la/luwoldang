<%- include('../partials/dash-top', { user: user, active: active, title: '회원 승인 · 관리' }) %>

<%
  function fmtDate(d) {
    if (!d) return '-';
    try { return new Date(d).toLocaleDateString('ko-KR',{timeZone:'Asia/Seoul'}); } catch (e) { return '-'; }
  }
  function roleLabel(r) { return r === 'admin' ? '관리자' : '교육생'; }
%>

<!-- 승인 대기 -->
<h2 class="section-h">승인 대기 <% if (pending.length) { %><span class="count"><%= pending.length %></span><% } %></h2>
<% if (pending.length === 0) { %>
  <div class="empty-box">승인 대기 중인 회원이 없습니다.</div>
<% } else { %>
  <div class="tbl">
    <% pending.forEach(function (u) { %>
      <div class="tbl-row">
        <div class="tbl-main">
          <div class="u-name"><%= u.name %> <span class="u-role"><%= roleLabel(u.role) %></span></div>
          <div class="u-sub">가입일 <%= fmtDate(u.created_at) %><% if (u.account_email) { %> · <%= u.account_email %><% } %></div>
        </div>
        <div class="tbl-actions">
          <form method="post" action="/admin/approve/<%= u.id %>">
            <button class="btn btn-approve" type="submit">승인</button>
          </form>
          <form method="post" action="/admin/reject/<%= u.id %>">
            <button class="btn btn-reject" type="submit">거절</button>
          </form>
        </div>
      </div>
    <% }); %>
  </div>
<% } %>

<!-- 승인 완료 -->
<h2 class="section-h" style="margin-top:36px;">승인 완료 <span class="count light"><%= approved.length %></span></h2>
<% if (approved.length === 0) { %>
  <div class="empty-box">승인된 회원이 없습니다.</div>
<% } else { %>
  <div class="tbl">
    <% approved.forEach(function (u) { %>
      <div class="tbl-row">
        <div class="tbl-main">
          <div class="u-name"><%= u.name %> <span class="u-role <%= u.role === 'admin' ? 'admin' : '' %>"><%= roleLabel(u.role) %></span></div>
          <div class="u-sub">승인일 <%= fmtDate(u.approved_at) %> · 링크코드 <%= u.slug %></div>
        </div>
        <div class="tbl-actions">
          <% if (String(u.id) === String(user.id)) { %>
            <span class="me-tag">나</span>
          <% } else { %>
            <% if (u.role === 'admin') { %>
              <form method="post" action="/admin/role/<%= u.id %>" onsubmit="return confirm('<%= u.name %>님의 관리자 권한을 내리고 교육생으로 바꿀까요?');">
                <input type="hidden" name="role" value="trainee">
                <button class="btn btn-ghost" type="submit">교육생으로</button>
              </form>
            <% } else { %>
              <form method="post" action="/admin/role/<%= u.id %>" onsubmit="return confirm('<%= u.name %>님을 관리자로 올릴까요?\n\n관리자는 모든 교육생의 기록과 회원 승인 권한을 갖습니다.');">
                <input type="hidden" name="role" value="admin">
                <button class="btn btn-ghost" type="submit">관리자로</button>
              </form>
            <% } %>
            <form method="post" action="/admin/revoke/<%= u.id %>" onsubmit="return confirm('이 회원을 다시 승인 대기 상태로 되돌릴까요?');">
              <button class="btn btn-ghost" type="submit">승인 해제</button>
            </form>
            <a class="btn btn-ghost as-btn" href="/auth/as/<%= u.id %>"
               onclick="return confirm('<%= u.name %>님 계정으로 전환할까요?\n\n상단의 [관리자로 돌아가기] 로 언제든 복귀할 수 있습니다.');">이 계정으로 보기</a>
          <% } %>
        </div>
      </div>
      <div class="note-row">
        <span class="note-ic">📝</span>
        <input type="text" class="note-input" data-id="<%= u.id %>" value="<%= u.admin_note || '' %>" placeholder="이 수강생 메모 (예: 실제 이름 / 연락처 / 특이사항)" onkeydown="if(event.key==='Enter')saveNote(<%= u.id %>, this)">
        <button class="note-save" onclick="saveNote(<%= u.id %>, this)">저장</button>
      </div>
    <% }); %>
  </div>
<% } %>

<style>
  .as-btn{display:inline-flex;align-items:center;text-decoration:none}
  .note-row { display:flex; align-items:center; gap:8px; background:#faf8f2; border:1px solid #ece6d8; border-radius:10px; padding:8px 12px; margin:-6px 0 14px; }
  .note-ic { font-size:15px; flex-shrink:0; }
  .note-input { flex:1; border:1px solid #ddd2b8; border-radius:7px; padding:8px 11px; font-size:13.5px; background:#fff; color:#4a3d28; }
  .note-input:focus { outline:none; border-color:#B59A62; }
  .note-save { padding:8px 15px; background:#B59A62; color:#fff; border:0; border-radius:7px; font-weight:700; font-size:13px; cursor:pointer; white-space:nowrap; }
  .note-toast { position:fixed; bottom:24px; left:50%; transform:translateX(-50%) translateY(10px); opacity:0; background:#333; color:#fff; padding:11px 20px; border-radius:24px; font-size:14px; z-index:99; transition:.25s; pointer-events:none; }
  .note-toast.show { opacity:1; transform:translateX(-50%) translateY(0); }
</style>
<div class="note-toast" id="noteToast"></div>
<script>
  async function saveNote(id, el){
    var row = el.closest('.note-row');
    var val = row.querySelector('.note-input').value.trim();
    var btn = row.querySelector('.note-save');
    btn.disabled = true; btn.textContent = '저장중';
    try {
      var r = await fetch('/admin/note/' + id, {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ note: val })
      });
      var d = await r.json();
      if (!d.ok) throw new Error(d.error || '실패');
      var t = document.getElementById('noteToast');
      t.textContent = '메모를 저장했습니다'; t.classList.add('show');
      setTimeout(function(){ t.classList.remove('show'); }, 1500);
    } catch(e){ alert('저장 실패: ' + e.message); }
    btn.textContent = '저장'; btn.disabled = false;
  }
</script>

<!-- 거절됨 -->
<% if (rejected.length > 0) { %>
  <h2 class="section-h" style="margin-top:36px;">거절됨 <span class="count light"><%= rejected.length %></span></h2>
  <div class="tbl">
    <% rejected.forEach(function (u) { %>
      <div class="tbl-row">
        <div class="tbl-main">
          <div class="u-name"><%= u.name %></div>
          <div class="u-sub">가입일 <%= fmtDate(u.created_at) %></div>
        </div>
        <div class="tbl-actions">
          <form method="post" action="/admin/approve/<%= u.id %>">
            <button class="btn btn-approve" type="submit">승인으로 변경</button>
          </form>
        </div>
      </div>
    <% }); %>
  </div>
<% } %>

<%- include('../partials/dash-bottom') %>
