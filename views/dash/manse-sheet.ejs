<%- include('../partials/dash-top', { user: user, active: active, title: '만세력 작성' }) %>

<div class="ms-toolbar no-cap">
  <p class="ms-guide">
    아래 표에 직접 입력하세요. 칸을 눌러 글자를 채우면 됩니다.
    다 채우면 <b>미리보기</b>를 누른 뒤 화면을 캡처하세요.
  </p>
  <div class="ms-btns">
    <button type="button" class="msb" onclick="clearAll()">전부 비우기</button>
    <button type="button" class="msb primary" id="capBtn" onclick="toggleCapture()">미리보기 (캡처 모드)</button>
  </div>
</div>

<!-- 실제 PDF 처럼 보이는 A4 종이 -->
<div class="paper-wrap">
  <section class="paper">
    <div class="corner tl"></div><div class="corner tr"></div>
    <div class="corner bl"></div><div class="corner br"></div>

    <h2 class="pg-title">만세력 · 사주 원국</h2>
    <div class="pg-line"></div>

    <div class="ms-meta">
      <p><b class="ce" contenteditable="true" data-ph="이름">홍길동</b>
         <span class="ce" contenteditable="true" data-ph="성별">남</span></p>
      <p>
        <span class="ce" contenteditable="true" data-ph="생년월일">1990-01-01</span>
        <span class="ce" contenteditable="true" data-ph="양력/음력">양력</span>
        <span class="ce" contenteditable="true" data-ph="태어난 시각">子시</span> ·
        <span class="ce" contenteditable="true" data-ph="지역">서울특별시</span>
      </p>
    </div>

    <table class="ms-chart">
      <tr class="ms-head">
        <th></th>
        <th>시주</th><th>일주</th><th>월주</th><th>연주</th>
      </tr>
      <tr>
        <th class="ms-rh">천간</th>
        <td class="gz"><span class="ce" contenteditable="true">庚</span></td>
        <td class="gz"><span class="ce" contenteditable="true">甲</span></td>
        <td class="gz"><span class="ce" contenteditable="true">丙</span></td>
        <td class="gz"><span class="ce" contenteditable="true">己</span></td>
      </tr>
      <tr>
        <th class="ms-rh">지지</th>
        <td class="gz"><span class="ce" contenteditable="true">午</span></td>
        <td class="gz"><span class="ce" contenteditable="true">子</span></td>
        <td class="gz"><span class="ce" contenteditable="true">寅</span></td>
        <td class="gz"><span class="ce" contenteditable="true">巳</span></td>
      </tr>
      <tr>
        <th class="ms-rh sm">지장간</th>
        <td class="sm"><span class="ce" contenteditable="true">丙己丁</span></td>
        <td class="sm"><span class="ce" contenteditable="true">壬癸</span></td>
        <td class="sm"><span class="ce" contenteditable="true">戊丙甲</span></td>
        <td class="sm"><span class="ce" contenteditable="true">戊庚丙</span></td>
      </tr>
      <tr>
        <th class="ms-rh sm">12운성</th>
        <td class="sm"><span class="ce" contenteditable="true">사</span></td>
        <td class="sm"><span class="ce" contenteditable="true">목욕</span></td>
        <td class="sm"><span class="ce" contenteditable="true">병</span></td>
        <td class="sm"><span class="ce" contenteditable="true">건록</span></td>
      </tr>
    </table>

    <h3 class="ms-h">강한 기운 · 부족한 기운</h3>
    <p class="ms-sum">
      강한 기운 <b class="ce" contenteditable="true">화</b> ·
      부족한 기운 <b class="ce" contenteditable="true">수</b>
    </p>

    <h3 class="ms-h">대운</h3>
    <table class="ms-dw">
      <tr>
        <% for (var i=0;i<8;i++){ %><th><span class="ce" contenteditable="true"><%= (i*10+3) %></span>세</th><% } %>
      </tr>
      <tr>
        <% for (var i=0;i<8;i++){ %>
          <td><b class="ce" contenteditable="true">-</b><i class="ce" contenteditable="true">干支</i></td>
        <% } %>
      </tr>
    </table>

    <p class="ms-foot">樓月堂 · 만세력</p>
  </section>
</div>

<style>
  /* ── 툴바 (캡처 시 숨김) ── */
  .ms-toolbar{max-width:820px;margin:0 auto 18px;padding:14px 18px;background:#fff;
    border:1px solid #e6e0d2;border-radius:12px;font-family:Pretendard,-apple-system,sans-serif}
  .ms-guide{margin:0 0 12px;font-size:13.5px;color:#6b6656;line-height:1.7}
  .ms-btns{display:flex;gap:8px;flex-wrap:wrap}
  .msb{padding:9px 16px;border:1px solid #d8cfb8;background:#fff;color:#6b6656;border-radius:8px;
    font-size:13px;font-weight:700;cursor:pointer;font-family:inherit}
  .msb.primary{background:#B59A62;border-color:#B59A62;color:#241a06}
  .msb:hover{opacity:.9}

  /* ── A4 종이 ── */
  .paper-wrap{display:flex;justify-content:center;padding:0 12px 60px}
  .paper{position:relative;width:100%;max-width:820px;aspect-ratio:210/297;
    background:#fdfbf4;border:1px solid #ece4d0;padding:56px 54px;box-sizing:border-box;
    box-shadow:0 6px 30px rgba(0,0,0,.08);font-family:'Nanum Myeongjo',serif}
  /* 모서리 장식선 (리포트 느낌) */
  .corner{position:absolute;width:44px;height:44px;border-color:#d8cdb0;border-style:solid;border-width:0}
  .corner.tl{top:20px;left:20px;border-top-width:2px;border-left-width:2px}
  .corner.tr{top:20px;right:20px;border-top-width:2px;border-right-width:2px}
  .corner.bl{bottom:20px;left:20px;border-bottom-width:2px;border-left-width:2px}
  .corner.br{bottom:20px;right:20px;border-bottom-width:2px;border-right-width:2px}

  .pg-title{font-family:'Nanum Myeongjo',serif;font-size:25px;font-weight:800;letter-spacing:3px;
    color:#1f2a3d;margin:0}
  .pg-line{height:2px;background:#c8a45c;width:64px;margin:10px 0 24px}

  .ms-meta{margin-bottom:20px;font-size:13px;color:#6b6656}
  .ms-meta p{margin:3px 0}
  .ms-meta b{font-size:16px;color:#2b2a26}

  .ms-chart{width:100%;border-collapse:collapse;margin-bottom:28px}
  .ms-chart th,.ms-chart td{border:1px solid #e6ddc9;text-align:center;padding:10px 4px;background:#fff}
  .ms-head th{background:#faf6ec;font-size:12.5px;color:#8a8574;font-weight:600}
  .ms-rh{background:#faf6ec;font-size:11.5px;color:#8a8574;width:56px}
  .ms-rh.sm{font-size:10.5px;color:#b3ad9c}
  .ms-chart td.gz .ce{font-family:'Nanum Myeongjo',serif;font-size:26px;font-weight:700;color:#2b2a26}
  .ms-chart td.sm .ce{font-size:12.5px;color:#5a5648}

  .ms-h{font-family:'Nanum Myeongjo',serif;font-size:15px;margin:24px 0 10px;padding-left:9px;
    border-left:3px solid #b59a62;color:#2b2a26}
  .ms-sum{text-align:center;font-size:14px;color:#7c7466}
  .ms-sum b{color:#1f2a3d}

  .ms-dw{width:100%;border-collapse:collapse}
  .ms-dw th,.ms-dw td{border:1px solid #e6ddc9;text-align:center;padding:8px 2px;background:#fff}
  .ms-dw th{background:#faf6ec;font-size:11px;color:#8a8574;font-weight:500}
  .ms-dw td b{display:block;font-family:'Nanum Myeongjo',serif;font-size:16px;color:#1f2a3d}
  .ms-dw td i{display:block;font-style:normal;font-size:10px;color:#b3ad9c}

  .ms-foot{text-align:center;margin-top:30px;font-size:11px;color:#c2b48f;letter-spacing:2px}

  /* ── 편집 가능한 칸 표시 ── */
  .ce{outline:none;cursor:text}
  .ce:empty::before{content:attr(data-ph);color:#cfc7b5;font-weight:400}
  body:not(.capturing) .ce:hover{background:#fbf3df;border-radius:3px}
  body:not(.capturing) .ce:focus{background:#fff7e6;box-shadow:0 0 0 2px #d8c48a;border-radius:3px}

  /* ── 캡처 모드: 편집 흔적·툴바 숨김 ── */
  body.capturing .no-cap{display:none}
  body.capturing .ce{background:none!important;box-shadow:none!important}
</style>

<script>
  var capturing = false;

  function toggleCapture(){
    capturing = !capturing;
    document.body.classList.toggle('capturing', capturing);
    document.querySelectorAll('.ce').forEach(function(el){
      el.setAttribute('contenteditable', capturing ? 'false' : 'true');
    });
    var btn = document.getElementById('capBtn');
    // 툴바 자체가 숨겨지므로, 캡처 해제용 떠있는 버튼을 따로 관리
    if (capturing) showExitBtn(); else hideExitBtn();
  }

  var exitBtn = null;
  function showExitBtn(){
    if (exitBtn) return;
    exitBtn = document.createElement('button');
    exitBtn.textContent = '✎ 편집으로 돌아가기';
    exitBtn.style.cssText = 'position:fixed;bottom:20px;right:20px;z-index:9999;padding:12px 18px;'+
      'border:0;border-radius:24px;background:#182234;color:#fff;font-weight:700;font-size:13px;'+
      'cursor:pointer;box-shadow:0 4px 16px rgba(0,0,0,.3);font-family:Pretendard,sans-serif';
    exitBtn.className = 'no-cap-keep';
    exitBtn.onclick = toggleCapture;
    document.body.appendChild(exitBtn);
  }
  function hideExitBtn(){ if(exitBtn){ exitBtn.remove(); exitBtn=null; } }

  function clearAll(){
    if(!confirm('입력한 내용을 전부 비울까요?')) return;
    document.querySelectorAll('.ce').forEach(function(el){ el.textContent=''; });
  }
</script>
