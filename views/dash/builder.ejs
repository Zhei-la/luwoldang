<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>랜딩 빌더 · 루월당</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css">
<link href="https://fonts.googleapis.com/css2?family=Gowun+Batang:wght@400;700&family=Nanum+Myeongjo:wght@400;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/builder.css">
</head>
<body>
<div class="shell">
  <div class="topbar">
    <a class="back" href="/home">← 대시보드</a>
    <div class="brand"><span class="moon"></span>랜딩 빌더</div>
    <div class="spacer"></div>
    <a class="btn sm" href="/s/<%= user.slug %>" target="_blank">내 페이지 열기 ↗</a>
    <button class="btn sm" id="btnCopy">링크 복사</button>
    <button class="btn gold" id="btnSave">저장하기</button>
  </div>
  <div class="panel left">
    <div class="ptitle">블록 · 드래그로 순서 변경</div>
    <div class="blocklist" id="blocklist"></div>
    <div class="addrow">
      <div class="ptitle" style="padding:0 4px 2px">블록 추가</div>
      <div class="addgrid" id="addgrid"></div>
    </div>
  </div>
  <div class="center">
    <div class="devicebar">
      <button class="chip on" data-w="phone">모바일</button>
      <button class="chip" data-w="wide">데스크탑</button>
      <span class="hintbar">저장하면 내 링크에 바로 반영됩니다</span>
    </div>
    <div class="phone" id="phone"><iframe id="pv"></iframe></div>
  </div>
  <div class="panel right" id="inspector"></div>
</div>
<div class="toast" id="toast"></div>
<input type="file" id="filePick" accept="image/*" hidden>
<script>window.__SLUG__ = '<%= user.slug %>'; window.__BASE__ = '<%= baseUrl %>';</script>
<script src="/js/builder.js"></script>
</body>
</html>
