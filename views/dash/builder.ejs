<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>랜딩 빌더 · 루월당</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css">
<link href="https://fonts.googleapis.com/css2?family=Gowun+Batang:wght@400;700&family=Nanum+Myeongjo:wght@400;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/builder.css">
</head>
<body>
<div class="shell">
  <div class="topbar">
    <a class="back" href="/home"><span class="lb-full">← 대시보드</span><span class="lb-mini">←</span></a>
    <div class="brand"><span class="moon"></span><span class="lb-full">랜딩 빌더</span><span class="lb-mini">빌더</span></div>
    <div class="spacer"></div>
    <button class="tgl" id="tglLeft" title="블록 목록 접기/펼치기">◧ 블록</button>
    <button class="tgl" id="tglRight" title="설정 패널 접기/펼치기">◨ 설정</button>
    <a class="btn sm" href="/s/<%= user.slug %>" target="_blank" title="내 페이지 열기"><span class="lb-full">내 페이지 열기 ↗</span><span class="lb-mini">↗</span></a>
    <button class="btn sm" id="btnCopy" title="링크 복사"><span class="lb-full">링크 복사</span><span class="lb-mini">링크</span></button>
    <button class="btn gold" id="btnSave">저장<span class="lb-full">하기</span></button>
  </div>
  <div class="mtabs" id="mtabs">
    <button data-tab="blocks">블록</button>
    <button data-tab="preview" class="on">미리보기</button>
    <button data-tab="settings">설정</button>
  </div>
  <div class="panel left">
    <div class="ptitle">블록 · 드래그로 순서 변경</div>
    <div class="blocklist" id="blocklist"></div>
    <div class="addrow">
      <div class="ptitle" style="padding:0 4px 2px">블록 추가</div>
      <div class="addgrid" id="addgrid"></div>
    </div>
  </div>
  <div class="center">
    <div class="devicebar">
      <button class="chip on" data-w="phone">모바일</button>
      <button class="chip" data-w="wide">데스크탑</button>
      <span class="hintbar">저장하면 내 링크에 바로 반영됩니다</span>
    </div>
    <div class="phone" id="phone"><iframe id="pv"></iframe></div>
  </div>
  <div class="panel right" id="inspector"></div>
</div>
<div class="toast" id="toast"></div>
<input type="file" id="filePick" accept="image/*" hidden>
<script>window.__SLUG__ = '<%= user.slug %>'; window.__BASE__ = '<%= baseUrl %>';</script>
<script>
/* 좌우 패널 접기 — 미리보기를 넓게 보기 위한 기능.
   접은 상태는 다음에 들어와도 유지된다. */
(function(){
  var shell = document.querySelector('.shell');
  function apply(side, hide){
    shell.classList.toggle('hide-' + side, hide);
    var btn = document.getElementById(side === 'left' ? 'tglLeft' : 'tglRight');
    if (btn) btn.classList.toggle('off', hide);
    try { localStorage.setItem('lb_hide_' + side, hide ? '1' : '0'); } catch(e){}
  }
  ['left','right'].forEach(function(side){
    var saved = '0';
    try { saved = localStorage.getItem('lb_hide_' + side) || '0'; } catch(e){}
    apply(side, saved === '1');
    var btn = document.getElementById(side === 'left' ? 'tglLeft' : 'tglRight');
    if (btn) btn.onclick = function(){ apply(side, !shell.classList.contains('hide-' + side)); };
  });
})();

/* 모바일 · 태블릿 — 좁은 화면에서는 3열이 들어가지 않으므로
   [블록] [미리보기] [설정] 탭으로 하나씩 전체화면으로 본다. */
(function(){
  var shell = document.querySelector('.shell');
  var tabs = document.getElementById('mtabs');
  if (!shell || !tabs) return;

  function go(name){
    shell.setAttribute('data-tab', name);
    tabs.querySelectorAll('button').forEach(function(b){
      b.classList.toggle('on', b.dataset.tab === name);
    });
    window.scrollTo(0, 0);
  }
  go('preview');

  tabs.querySelectorAll('button').forEach(function(b){
    b.onclick = function(){ go(b.dataset.tab); };
  });

  // 블록을 고르면 바로 설정 탭으로 넘어간다 (모바일에서 자연스러운 흐름)
  document.addEventListener('click', function(e){
    if (window.innerWidth > 900) return;
    var item = e.target.closest && e.target.closest('.bitem');
    if (item && !e.target.dataset.del) setTimeout(function(){ go('settings'); }, 60);
  });

  // 저장하면 결과를 볼 수 있게 미리보기로
  var save = document.getElementById('btnSave');
  if (save) save.addEventListener('click', function(){
    if (window.innerWidth <= 900) setTimeout(function(){ go('preview'); }, 400);
  });
})();
</script>
<script src="/js/builder.js"></script>
</body>
</html>
