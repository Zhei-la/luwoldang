<%- include('../partials/dash-top', { user: user, active: active, title: 'PDF 표지 꾸미기' }) %>

<div class="settings-block">
  <h2 class="section-h">표지 디자인 세트</h2>
  <p class="block-desc">
    디자인 세트를 하나 고르면 <b>8종 리포트 표지가 모두 그 디자인</b>으로 나갑니다.
    세트를 고른 뒤에도, 아래에서 특정 종류만 <b>내 표지로 따로</b> 바꿀 수 있습니다.
  </p>

  <div class="set-grid">
    <% var kindEn = {'종합사주':'jonghap','신년운세':'sinnyeon','무료사주':'free','연인궁합':'gunghap','연애운':'yeonae','결혼운':'gyeolhon','재물운':'jaemul','건강운':'geongang'}; %>
    <% sets.forEach(function (s) { var on = (chosen === s.key); %>
      <div class="set-card <%= on ? 'on' : '' %>">
        <div class="set-preview">
          <% var previewKinds = (s.kinds || ['종합사주','신년운세','연애운','건강운']).slice(0,4); %>
          <% previewKinds.forEach(function (k) { %>
            <% var src; if (s.key === 'original') { src = '/img/pdf/cover-' + kindEn[k] + '.jpg'; } else if (s.custom) { src = '/covers/set-img/' + s.key + '/' + encodeURIComponent(k); } else { src = '/img/covers/' + s.key + '/' + kindEn[k] + '.jpg'; } %>
            <div class="set-thumb" style="background-image:url('<%= src %>')"></div>
          <% }); %>
        </div>
        <div class="set-name"><%= s.name %><% if (on) { %> <span class="set-chk">✓ 사용 중</span><% } %></div>
        <button type="button" class="set-btn <%= on ? 'ghost' : '' %>" onclick="chooseSet('<%= s.key %>', <%= on %>)">
          <%= on ? '해제' : '이 세트 사용' %>
        </button>
      </div>
    <% }); %>
  </div>
</div>

<div class="settings-block">
  <h2 class="section-h">종류별 내 표지 (선택)</h2>
  <p class="block-desc">
    특정 종류만 <b>나만의 표지</b>로 바꾸고 싶을 때 사용합니다.
    올린 표지는 세트보다 우선합니다. A4 세로 비율, JPG·PNG, 3MB 이하.
  </p>
</div>

<div class="settings-block">
  <div class="cv-grid">
    <% types.forEach(function (t) { var has = mine[t]; %>
      <div class="cv-card" data-type="<%= t %>">
        <div class="cv-thumb <%= has ? 'on' : '' %>"<% if (has) { %> style="background-image:url('/covers/my-img/<%= encodeURIComponent(t) %>?v=<%= Date.now() %>')"<% } %>>
          <% if (has) { %>
            <span class="cv-badge">내 표지</span>
          <% } else { %>
            <span class="cv-thumb-txt muted">기본 표지</span>
          <% } %>
        </div>
        <div class="cv-name"><%= t %></div>
        <div class="cv-actions">
          <label class="cv-btn">
            <%= has ? '바꾸기' : '올리기' %>
            <input type="file" accept="image/*" hidden onchange="uploadCover(this, '<%= t %>')">
          </label>
          <% if (has) { %>
            <button type="button" class="cv-btn ghost" onclick="deleteCover('<%= t %>')">기본으로</button>
          <% } %>
        </div>
      </div>
    <% }); %>
  </div>
</div>

<div class="settings-block">
  <h2 class="section-h">본문 배경지</h2>
  <p class="block-desc">
    리포트 <b>본문 페이지</b>에 깔리는 종이 배경입니다. 표지와는 별개입니다.
    하나 고르면 모든 본문 페이지에 적용됩니다.
  </p>
  <div class="paper-grid">
    <% papers.forEach(function (p) { var on = (chosenPaper === p.key) || (!chosenPaper && p.key === 'frame'); %>
      <div class="paper-card <%= on ? 'on' : '' %>">
        <div class="paper-thumb" style="background-image:url('<%= p.img %>')"></div>
        <div class="paper-name"><%= p.name %><% if (on) { %> <span class="paper-chk">✓</span><% } %></div>
        <button type="button" class="paper-btn <%= on ? 'ghost' : '' %>" onclick="choosePaper('<%= p.key %>')">
          <%= on ? '사용 중' : '선택' %>
        </button>
      </div>
    <% }); %>
  </div>
</div>

<div class="toast" id="toast"></div>

<style>
  /* 세트 선택 */
  .set-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:16px; }
  .set-card { border:1px solid #e6e0d2; border-radius:12px; padding:12px; background:#fff; transition:.15s; }
  .set-card.on { border-color:#B59A62; box-shadow:0 0 0 2px #e8d9b3; }
  .set-preview { display:grid; grid-template-columns:1fr 1fr; gap:4px; margin-bottom:10px; }
  .set-thumb { aspect-ratio:1/1.414; border-radius:5px; background:#f3efe4 center/cover no-repeat; border:1px solid #ece4d0; }
  .set-name { font-weight:700; font-size:14px; color:#3a3527; margin-bottom:10px; }
  .set-chk { color:#B59A62; font-size:12px; font-weight:800; }
  .set-btn { width:100%; padding:9px; border:0; border-radius:8px; background:#B59A62; color:#241a06;
    font-weight:800; font-size:13px; cursor:pointer; font-family:inherit; }
  .set-btn.ghost { background:#fff; border:1px solid #d8cfb8; color:#6b6656; font-weight:600; }
  .set-btn:hover { opacity:.9; }

  /* 배경지 */
  .paper-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(130px,1fr)); gap:14px; }
  .paper-card { border:1px solid #e6e0d2; border-radius:10px; padding:10px; background:#fff; text-align:center; }
  .paper-card.on { border-color:#B59A62; box-shadow:0 0 0 2px #e8d9b3; }
  .paper-thumb { aspect-ratio:1/1.414; border-radius:6px; background:#f3efe4 center/cover no-repeat;
    border:1px solid #ece4d0; margin-bottom:8px; }
  .paper-name { font-size:13px; font-weight:700; color:#3a3527; margin-bottom:8px; }
  .paper-chk { color:#B59A62; font-weight:900; }
  .paper-btn { width:100%; padding:8px; border:0; border-radius:7px; background:#B59A62; color:#241a06;
    font-weight:800; font-size:12.5px; cursor:pointer; font-family:inherit; }
  .paper-btn.ghost { background:#fff; border:1px solid #d8cfb8; color:#6b6656; font-weight:600; }
  .paper-btn:hover { opacity:.9; }

</style>
<style>
  .cv-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(150px,1fr)); gap:16px; }
  .cv-card { border:1px solid #e6e0d2; border-radius:12px; padding:12px; background:#fff; }
  .cv-thumb { aspect-ratio:1/1.414; border-radius:8px; background:#f3efe4; border:1px dashed #d8cfb8;
    display:flex; flex-direction:column; align-items:center; justify-content:center; gap:6px;
    position:relative; overflow:hidden; background-size:cover; background-position:center; }
  .cv-thumb.on { border-style:solid; border-color:#B59A62; }
  .cv-thumb-txt { font-size:12px; color:#8a6f3c; font-weight:700; }
  .cv-thumb-txt.muted { color:#b3ad9c; font-weight:500; }
  .cv-badge { position:absolute; top:8px; left:8px; background:#B59A62; color:#fff;
    font-size:10.5px; font-weight:800; padding:3px 8px; border-radius:20px; }
  .cv-name { margin:10px 2px 8px; font-weight:700; font-size:14px; color:#3a3527; }
  .cv-actions { display:flex; gap:6px; }
  .cv-btn { flex:1; text-align:center; padding:8px 4px; border-radius:7px; cursor:pointer;
    font-size:12.5px; font-weight:700; background:#B59A62; color:#241a06; border:0;
    font-family:inherit; display:inline-flex; align-items:center; justify-content:center; }
  .cv-btn.ghost { background:#fff; border:1px solid #d8cfb8; color:#6b6656; font-weight:600; }
  .cv-btn:hover { opacity:.9; }
  .toast { position:fixed; bottom:24px; left:50%; transform:translateX(-50%) translateY(10px); opacity:0;
    background:#2f9e5e; color:#fff; padding:10px 20px; border-radius:8px; font-size:13px; font-weight:700;
    z-index:99; transition:.25s; pointer-events:none; }
  .toast.on { opacity:1; transform:translateX(-50%); }
</style>

<script>
  function toast(msg, bad) {
    var t = document.getElementById('toast');
    t.textContent = msg;
    t.style.background = bad ? '#c0392b' : '#2f9e5e';
    t.classList.add('on');
    setTimeout(function () { t.classList.remove('on'); }, 2000);
  }

  async function chooseSet(key, isOn) {
    try {
      var r = await fetch('/covers/choose-set', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ setKey: isOn ? null : key })
      });
      var d = await r.json();
      if (!d.ok) throw new Error(d.error || '실패');
      toast(isOn ? '세트를 해제했습니다' : '세트를 적용했습니다');
      setTimeout(function () { location.reload(); }, 700);
    } catch (e) { toast(e.message, true); }
  }

  async function choosePaper(key) {
    try {
      var r = await fetch('/covers/choose-paper', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ paperKey: key })
      });
      var d = await r.json();
      if (!d.ok) throw new Error(d.error || '실패');
      toast('배경지를 적용했습니다');
      setTimeout(function () { location.reload(); }, 700);
    } catch (e) { toast(e.message, true); }
  }

  function uploadCover(input, type) {
    var file = input.files && input.files[0];
    input.value = '';
    if (!file) return;
    if (file.size > 3 * 1024 * 1024) { toast('이미지가 너무 큽니다. 3MB 이하로 올려주세요.', true); return; }

    var reader = new FileReader();
    reader.onload = async function () {
      var card = document.querySelector('.cv-card[data-type="' + type + '"] .cv-thumb');
      toast('올리는 중...');
      try {
        var r = await fetch('/covers/upload', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: type, img: reader.result, style: 'plain' })
        });
        var d = await r.json();
        if (!d.ok) throw new Error(d.error || '실패');
        // 화면에 바로 반영
        if (card) {
          card.style.backgroundImage = "url('" + reader.result + "')";
          card.classList.add('on');
          card.innerHTML = '<span class="cv-badge">내 표지</span>';
        }
        toast('표지를 올렸습니다');
        setTimeout(function () { location.reload(); }, 900);
      } catch (e) {
        toast(e.message, true);
      }
    };
    reader.readAsDataURL(file);
  }

  async function deleteCover(type) {
    if (!confirm(type + ' 표지를 기본으로 되돌릴까요?')) return;
    try {
      var r = await fetch('/covers/delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type: type })
      });
      var d = await r.json();
      if (!d.ok) throw new Error(d.error || '실패');
      toast('기본 표지로 되돌렸습니다');
      setTimeout(function () { location.reload(); }, 700);
    } catch (e) {
      toast(e.message, true);
    }
  }
</script>

<%- include('../partials/dash-bottom') %>
