<script>
/* ===== 무료 PDF 뒷장 설정 ===== */
(function(){
  var imgs = <%- JSON.stringify(promo.reviews.images || []) %>;
  var list = document.getElementById('pmRvList');
  var file = document.getElementById('pmRvFile');
  var box  = document.getElementById('pmBox');
  var show = document.getElementById('pmShow');
  if (!list) return;

  function paint(){
    list.innerHTML = imgs.map(function(src, i){
      return '<div style="position:relative">' +
        '<img src="' + src + '" style="width:100%;border:1px solid #E9E0CF;border-radius:6px;display:block">' +
        '<button type="button" data-i="' + i + '" style="position:absolute;top:4px;right:4px;width:22px;height:22px;' +
        'border:0;border-radius:50%;background:rgba(0,0,0,.65);color:#fff;cursor:pointer;line-height:1">×</button></div>';
    }).join('');
    list.querySelectorAll('button').forEach(function(b){
      b.onclick = function(){ imgs.splice(+b.dataset.i, 1); paint(); };
    });
  }

  // 캔버스로 줄여서 저장 (원본 그대로 넣으면 DB가 터진다)
  var tallWarned = false;
  function shrink(f){
    return new Promise(function(resolve, reject){
      var img = new Image();
      img.onload = function(){
        var w = img.width, h = img.height;

        // 세로가 가로의 2배를 넘으면 PDF에서 작게 보인다
        if (h / w > 2 && !tallWarned) {
          tallWarned = true;
          alert('세로로 아주 긴 이미지입니다.\n\n' +
                'PDF 한 장에 맞추려고 줄이면 글씨가 작아집니다.\n' +
                '후기를 한두 개씩 잘라서 여러 장으로 올리면 훨씬 잘 나옵니다.');
        }

        // 긴 변을 1200px로 (가로든 세로든)
        var MAX = 1200;
        var long = Math.max(w, h);
        if (long > MAX) {
          var r = MAX / long;
          w = Math.round(w * r);
          h = Math.round(h * r);
        }
        var c = document.createElement('canvas');
        c.width = w; c.height = h;
        var ctx = c.getContext('2d');
        ctx.fillStyle = '#fff';
        ctx.fillRect(0, 0, w, h);
        ctx.drawImage(img, 0, 0, w, h);
        resolve(c.toDataURL('image/jpeg', 0.75));
      };
      img.onerror = reject;
      img.src = URL.createObjectURL(f);
    });
  }

  file.onchange = async function(){
    for (var i = 0; i < file.files.length; i++) {
      if (imgs.length >= 6) { alert('후기 이미지는 최대 6장까지 넣을 수 있어요.'); break; }
      try { imgs.push(await shrink(file.files[i])); } catch (e) { /* 무시 */ }
    }
    file.value = '';
    paint();
  };

  function toggle(){ box.style.display = show.checked ? '' : 'none'; }
  show.onchange = toggle;
  toggle();
  paint();

  // 저장 직전에 JSON으로 묶어서 hidden 필드에 넣는다
  var form = document.querySelector('.settings-form');
  form.addEventListener('submit', function(){
    var v = function(id){ var el = document.getElementById(id); return el ? el.value : ''; };
    document.getElementById('promoJson').value = JSON.stringify({
      show: show.checked,
      manseEssay: v('pmManse'),
      premium: { title: v('pmPremTitle'), body: v('pmPremBody') },
      qa: {
        title: v('pmQaTitle'),
        intro: v('pmQaIntro'),
        items: v('pmQaItems').split('\n').map(function(x){ return x.trim(); }).filter(Boolean),
      },
      reviews: { title: v('pmRvTitle'), images: imgs },
      discount: {
        title: v('pmDcTitle'), body: v('pmDcBody'),
        off: v('pmDcOff'), priceWas: v('pmDcWas'), priceNow: v('pmDcNow'),
        btn: v('pmDcBtn'),
        btnColor: v('pmDcBtnColor'), btnTextColor: v('pmDcBtnText'), accentColor: v('pmDcAccent'),
      },
    });
  });
})();
</script>

<script>
/* 링크 주소 변경 — 되돌릴 수 없으니 한 번 더 확인 */
function confirmSlug(){
  var el = document.getElementById('slugIn');
  var v = (el.value || '').trim().toLowerCase();
  el.value = v;
  if (v === '<%= user.slug %>') return true;
  return confirm(
    '링크 주소를 "' + v + '" 로 바꿉니다.\n\n' +
    '예전 링크(/s/<%= user.slug %>)는 더 이상 열리지 않습니다.\n' +
    '이미 공유한 곳이 있다면 모두 새 주소로 바꿔야 합니다.\n\n계속할까요?'
  );
}
</script>

<script>
/* 할인 안내 — 할인율 / 정가 / 할인가 양방향 자동 계산 */
(function(){
  var off = document.getElementById('pmDcOff');
  var was = document.getElementById('pmDcWas');
  var now = document.getElementById('pmDcNow');
  if (!off || !was || !now) return;

  function numOf(v){
    var d = String(v || '').replace(/[^0-9.]/g, '');
    return d ? parseFloat(d) : NaN;
  }
  function won(v){ return v.toLocaleString('ko-KR') + '원'; }
  function okOff(o){ return isFinite(o) && o > 0 && o < 100; }

  // 정가 + 할인율 → 할인가
  function toNow(){
    var w = numOf(was.value), o = numOf(off.value);
    if (!isFinite(w) || !okOff(o)) return;
    now.value = won(Math.round(w * (1 - o / 100) / 100) * 100);
  }
  // 할인가 + 할인율 → 정가
  function toWas(){
    var n = numOf(now.value), o = numOf(off.value);
    if (!isFinite(n) || n <= 0 || !okOff(o)) return;
    was.value = won(Math.round(n / (1 - o / 100) / 100) * 100);
  }

  was.addEventListener('input', toNow);
  now.addEventListener('input', toWas);
  off.addEventListener('input', function(){
    if (String(was.value).trim()) toNow();
    else if (String(now.value).trim()) toWas();
  });
})();
</script>

<script>
/* 버튼 색 미리보기 */
(function(){
  var bg = document.getElementById('pmDcBtnColor');
  var tc = document.getElementById('pmDcBtnText');
  var txt = document.getElementById('pmDcBtn');
  var box = document.getElementById('pmBtnPreview');
  if (!bg || !box) return;
  function paint(){
    box.style.background = bg.value;
    box.style.color = tc.value;
    box.textContent = (txt.value || '').trim() || '할인받고 상담 신청하기';
  }
  [bg, tc, txt].forEach(function(el){ el.addEventListener('input', paint); });
  paint();
})();
</script>
