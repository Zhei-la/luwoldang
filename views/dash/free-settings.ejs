<%- include('../partials/dash-top', { user: user, active: active, title: '무료사주 웹사이트 설정' }) %>

<% var shareUrl = baseUrl + '/s/' + user.slug; %>

<% if (saved) { %><div class="save-toast">저장되었습니다.</div><% } %>

<!-- 공유 링크 -->
<div class="settings-block">
  <h2 class="section-h">내 웹사이트 링크</h2>
  <p class="block-desc">이 링크를 공유하면 내가 꾸민 랜딩 페이지가 열립니다. <a href="/builder">웹사이트 꾸미러 가기 →</a></p>
  <div class="share-row">
    <input class="fi share-input" id="shareUrl" type="text" value="<%= shareUrl %>" readonly>
    <button class="btn btn-approve" type="button" onclick="copyShare()">복사</button>
    <a class="btn btn-ghost" href="<%= shareUrl %>" target="_blank">미리보기</a>
  </div>

  <!-- 링크 주소 바꾸기 -->
  <label class="fl" style="margin-top:20px">링크 주소 바꾸기</label>
  <% if (slugError) { %><div class="free-error" style="margin-bottom:8px"><%= slugError %></div><% } %>
  <form method="post" action="/free-saju-settings/slug" class="share-row" onsubmit="return confirmSlug()">
    <span class="slug-pre"><%= baseUrl %>/s/</span>
    <input class="fi" type="text" name="slug" id="slugIn" value="<%= user.slug %>"
           pattern="[a-zA-Z0-9-]{3,24}" required
           placeholder="mysaju" style="flex:1;min-width:120px">
    <button class="btn btn-approve" type="submit">변경</button>
  </form>
  <p class="block-desc" style="margin-top:8px">
    영문·숫자·하이픈(-)만, 3~24자. 예: <b>mysaju</b>, <b>moon-saju</b>, <b>hong-gildong</b><br>
    ⚠️ 바꾸면 <b>예전 링크는 열리지 않습니다.</b> 이미 공유한 곳이 있으면 주의하세요.
  </p>
</div>

<!-- 설정 폼 -->
<form method="post" action="/free-saju-settings" class="settings-form">
  <div class="settings-block">
    <h2 class="section-h">사이트 정보</h2>

    <label class="fl">사이트 이름 (무료사주 첫 화면 제목)</label>
    <input class="fi" type="text" name="site_name" value="<%= user.site_name || '' %>" placeholder="예: 루월당">

    <label class="fl">OpenAI API 키 <% if (hasKey) { %><span class="key-ok">저장됨 ✓</span><% } %></label>
    <input class="fi" type="password" name="openai_key" placeholder="<%= hasKey ? '변경하려면 새 키 입력 (비우면 유지)' : 'sk-... 무료사주 생성에 사용됩니다' %>" autocomplete="off">
    <p class="hint">무료사주 결과 생성은 이 키로 호출됩니다. <a href="https://platform.openai.com/api-keys" target="_blank">키 발급받기</a></p>
  </div>

  <div class="settings-block">
    <h2 class="section-h">이메일 발송 설정
      <% if (mailReady) { %><span class="key-ok">사용 가능 ✓</span><% } %>
    </h2>

    <% if (!mailDomain) { %>
      <div class="warn-box" style="margin-bottom:16px">
        메일 발송이 아직 준비되지 않았습니다. 관리자에게 문의해주세요.
      </div>
    <% } else { %>
      <p class="block-desc">
        무료사주와 사주 리포트를 <b>내 이름으로</b> 보냅니다. 별도 가입이나 비용 없이 바로 사용할 수 있습니다.
      </p>

      <!-- 발신 미리보기 -->
      <div class="mail-preview">
        <div class="mp-label">받는 사람에게 이렇게 보입니다</div>
        <div class="mp-box">
          <b id="pvName"><%= user.mail_name || user.site_name || user.name || '사주 풀이' %></b>
          <span id="pvAddr">&lt;<%= (user.mail_local || 'noreply') %>@<%= mailDomain %>&gt;</span>
        </div>
      </div>

      <label class="fl">발신인 이름</label>
      <input class="fi" type="text" id="mailNameInput" name="mail_name"
             value="<%= user.mail_name || '' %>" placeholder="<%= user.site_name || '예: 운명삼문' %>">
      <p class="hint">받는 사람 메일함에 <b>크게 표시되는 이름</b>입니다.</p>

      <label class="fl">메일 아이디</label>
      <div class="mail-id-row">
        <input class="fi" type="text" id="mailLocalInput" name="mail_local"
               value="<%= user.mail_local || '' %>" placeholder="noreply" autocomplete="off">
        <span class="mail-domain">@<%= mailDomain %></span>
      </div>
      <p class="hint">영문 소문자·숫자만 사용할 수 있습니다. 비우면 <b>noreply</b>로 발송됩니다.</p>

      <label class="fl">답장 받을 주소</label>
      <input class="fi" type="email" name="mail_reply" value="<%= user.mail_reply || '' %>"
             placeholder="내 개인 이메일 (예: myname@naver.com)">
      <p class="hint">내담자가 <b>답장</b>을 누르면 이 주소로 옵니다. 비우면 답장을 받을 수 없습니다.</p>

      <div class="test-row">
        <input class="fi" type="email" id="testTo" placeholder="테스트 받을 이메일" value="<%= user.mail_reply || '' %>">
        <button class="btn btn-ghost" type="button" id="btnTestMail">테스트 발송</button>
      </div>
      <div class="prog" id="mailProg"></div>
      <p class="hint">먼저 <b>설정 저장</b>을 누른 뒤 테스트하세요.</p>
    <% } %>
  </div>

  <div class="settings-block">
    <h2 class="section-h">상담 연결 설정</h2>

    <label class="fl">카카오톡 상담 링크</label>
    <input class="fi" type="text" name="kakao_consult_link" value="<%= user.kakao_consult_link || '' %>" placeholder="예: https://open.kakao.com/o/...">

    <label class="fl">상담 안내 문구</label>
    <textarea class="fi" name="consult_message" rows="2" placeholder="무료사주는 전체 흐름을 간단히 보는 용도입니다. 내 사주를 더 자세히 알고 싶다면 전문 상담을 받아보세요."><%= user.consult_message || '' %></textarea>

    <label class="fl">상담 버튼 문구</label>
    <input class="fi" type="text" name="button_text" list="btnExamples" value="<%= user.button_text || '' %>" placeholder="비우면 기본 문구 사용">
    <datalist id="btnExamples">
      <option value="카카오톡으로 상담받기">
      <option value="내 사주 더 자세히 상담받기">
      <option value="유료 PDF 상담 신청하기">
      <option value="선생님에게 바로 문의하기">
      <option value="나에게 맞는 운세 상담받기">
    </datalist>
    <p class="hint">직접 입력하거나 칸을 클릭해 예시 중 선택할 수 있습니다.</p>
  </div>

  <div class="settings-block">
    <h2 class="section-h">리포트 후기 받기</h2>
    <label class="fl" style="display:flex;align-items:center;gap:8px">
      <input type="checkbox" name="review_on" <%= (user.review_on === false ? '' : 'checked') %>>
      리포트 맨 아래에 후기 작성란 넣기
    </label>
    <p class="hint">
      켜면, 리포트를 받은 사람이 리포트 맨 아래에서 별점·후기·사진을 남길 수 있습니다.
      남긴 후기는 <b>후기 메뉴</b>에서 확인하고, 골라서 내 웹사이트에 띄울 수 있습니다.<br>
      리포트 하나당 한 번만 작성되며, 다시 쓰면 이전 후기가 갱신됩니다.
    </p>

    <label class="fl">후기 유도 문구 <span style="color:#8a8574;font-weight:400">(선택)</span></label>
    <textarea class="fi" name="review_notice" rows="2" list="rvExamples" placeholder="예: 후기를 남겨주시면 추가 질문 1회를 무료로 드립니다."><%= user.review_notice || '' %></textarea>
    <datalist id="rvExamples">
      <option value="후기를 남겨주시면 추가 질문 1회를 무료로 드립니다.">
      <option value="솔직한 후기를 남겨주시면 다음 상담 때 할인해 드립니다.">
      <option value="후기를 남겨주시면 더 정성껏 답변드리겠습니다.">
    </datalist>
    <p class="hint">후기 작성란 위에 눈에 띄게 표시됩니다. 후기를 남길 이유를 만들어주면 훨씬 많이 작성합니다.</p>
  </div>

  <div class="settings-block">
    <h2 class="section-h">PDF 마지막 페이지 · 추가질문 버튼</h2>
    <p class="block-desc">
      리포트 마지막 장에 <b>추가질문 버튼</b>이 들어갑니다. 위에서 등록한 <b>카카오톡 상담 링크</b>로 연결됩니다.
      <% if (!user.kakao_consult_link) { %>
        <br><span class="warn-inline">⚠️ 카카오톡 상담 링크를 먼저 등록해야 버튼이 표시됩니다.</span>
      <% } %>
    </p>

    <label class="fl">버튼 문구</label>
    <input class="fi" type="text" name="pdf_cta_text" list="ctaExamples"
           value="<%= user.pdf_cta_text || '' %>" placeholder="추가 질문하러 가기">
    <datalist id="ctaExamples">
      <option value="추가 질문하러 가기">
      <option value="카카오톡으로 물어보기">
      <option value="더 자세히 상담받기">
      <option value="궁금한 점 물어보기">
      <option value="1:1 상담 신청하기">
    </datalist>
    <p class="hint">칸을 클릭하면 예시를 고를 수 있습니다. 비우면 <b>추가 질문하러 가기</b>로 표시됩니다.</p>

    <label class="fl">버튼 위 안내 문구</label>
    <textarea class="fi" name="pdf_cta_desc" rows="3" placeholder="리포트를 읽고 더 궁금한 점이 생기셨다면&#10;아래 버튼을 눌러 편하게 물어보세요."><%= user.pdf_cta_desc || '' %></textarea>
    <p class="hint">줄바꿈이 그대로 반영됩니다.</p>
  </div>

  <!-- ===== 무료사주 PDF — 뒷장 안내 페이지 ===== -->
  <div class="settings-block">
    <h2 class="section-h">무료사주 PDF 뒷장 (상담 유도 페이지)</h2>
    <p class="block-desc">
      무료 PDF 마지막에 붙는 안내 페이지입니다. 내용을 비우면 기본 문구가 들어갑니다.
      아래 브랜드명(<b><%= user.site_name || '사이트 이름 미설정' %></b>)이 PDF 모든 장 하단에 찍힙니다.
    </p>

    <label class="fl" style="display:flex;align-items:center;gap:8px">
      <input type="checkbox" id="pmShow" <%= promo.show ? 'checked' : '' %>>
      뒷장 안내 페이지 넣기
    </label>

    <div id="pmBox">
      <label class="fl">만세력 이해하기 (모든 리포트에 공통으로 들어가는 해설)</label>
      <textarea class="fi" id="pmManse" rows="6"><%= promo.manseEssay %></textarea>

      <hr style="border:0;border-top:1px solid #E9E0CF;margin:22px 0">

      <label class="fl">① 프리미엄 안내 — 제목 (줄바꿈 가능)</label>
      <textarea class="fi" id="pmPremTitle" rows="2"><%= promo.premium.title %></textarea>
      <label class="fl">① 프리미엄 안내 — 본문</label>
      <textarea class="fi" id="pmPremBody" rows="7"><%= promo.premium.body %></textarea>

      <hr style="border:0;border-top:1px solid #E9E0CF;margin:22px 0">

      <label class="fl">② 답변드립니다 — 제목</label>
      <textarea class="fi" id="pmQaTitle" rows="2"><%= promo.qa.title %></textarea>
      <label class="fl">② 답변드립니다 — 안내 문구</label>
      <textarea class="fi" id="pmQaIntro" rows="2"><%= promo.qa.intro %></textarea>
      <label class="fl">② 실제 받은 질문 (한 줄에 하나씩 · 최대 8개까지 PDF에 들어감)</label>
      <textarea class="fi" id="pmQaItems" rows="7"><%= promo.qa.items.join('\n') %></textarea>

      <hr style="border:0;border-top:1px solid #E9E0CF;margin:22px 0">

      <label class="fl">③ 후기 — 제목</label>
      <input class="fi" type="text" id="pmRvTitle" value="<%= promo.reviews.title %>">
      <label class="fl">③ 후기 이미지 (최대 6장)</label>
      <p class="block-desc" style="margin:-4px 0 10px">
        <b>권장 규격</b> — 가로 <b>900~1200px</b>, 비율 <b>3:4 · 1:1 · 4:3</b> 중 하나.<br>
        올리면 자동으로 줄여서 저장됩니다. 용량은 신경 쓰지 않아도 됩니다.<br>
        ⚠️ 세로로 아주 긴 통짜 캡처(스크린샷 전체)는 <b>PDF 한 장에 다 안 들어가</b> 작게 보입니다.
        후기 <b>한두 개씩 잘라서</b> 여러 장으로 올리는 게 훨씬 잘 나옵니다.
      </p>
      <input type="file" id="pmRvFile" accept="image/*" multiple style="margin-bottom:10px">
      <div id="pmRvList" style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px"></div>

      <hr style="border:0;border-top:1px solid #E9E0CF;margin:22px 0">

      <label class="fl">④ 할인 안내 — 제목 (줄바꿈 가능)</label>
      <textarea class="fi" id="pmDcTitle" rows="2"><%= promo.discount.title %></textarea>
      <label class="fl">④ 할인 안내 — 본문</label>
      <textarea class="fi" id="pmDcBody" rows="6"><%= promo.discount.body %></textarea>

      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px">
        <div>
          <label class="fl">할인율</label>
          <input class="fi" type="text" id="pmDcOff" value="<%= promo.discount.off || '' %>" placeholder="50%">
        </div>
        <div>
          <label class="fl">정가</label>
          <input class="fi" type="text" id="pmDcWas" value="<%= promo.discount.priceWas || '' %>" placeholder="60,000원">
        </div>
        <div>
          <label class="fl">할인가</label>
          <input class="fi" type="text" id="pmDcNow" value="<%= promo.discount.priceNow || '' %>" placeholder="29,800원">
        </div>
      </div>

      <label class="fl">④ 버튼 문구 (누르면 위에 등록한 카카오 상담 링크로 연결됩니다)</label>
      <input class="fi" type="text" id="pmDcBtn" value="<%= promo.discount.btn %>" placeholder="할인받고 상담 신청하기">

      <label class="fl" style="margin-top:16px">④ 색</label>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px">
        <div>
          <span class="fl" style="font-weight:400;font-size:11.5px">버튼 배경</span>
          <input type="color" id="pmDcBtnColor" value="<%= promo.discount.btnColor %>" class="fi-color">
        </div>
        <div>
          <span class="fl" style="font-weight:400;font-size:11.5px">버튼 글자</span>
          <input type="color" id="pmDcBtnText" value="<%= promo.discount.btnTextColor %>" class="fi-color">
        </div>
        <div>
          <span class="fl" style="font-weight:400;font-size:11.5px">할인율 강조</span>
          <input type="color" id="pmDcAccent" value="<%= promo.discount.accentColor %>" class="fi-color">
        </div>
      </div>
      <div id="pmBtnPreview" style="margin-top:12px;padding:15px;border-radius:5px;text-align:center;font-weight:800;font-size:15px">
        미리보기
      </div>
    </div>

    <input type="hidden" name="promo_json" id="promoJson">
  </div>

  <button class="free-save-btn" type="submit">설정 저장</button>
</form>

<script>
  // 저장된 키 확인
  var btnStatus = document.getElementById('btnMailStatus');
  if (btnStatus) {
    btnStatus.onclick = async function(){
      var prog = document.getElementById('mailProg');
      try {
        var r = await fetch('/api/mail/status');
        var d = await r.json();
        var lines = [];
        lines.push('API 키: ' + (d.apiKey ? d.apiKey.preview + ' (' + d.apiKey.length + '자)' : '없음'));
        lines.push('비밀 키: ' + (d.secretKey ? d.secretKey.preview + ' (' + d.secretKey.length + '자)' : '없음'));
        lines.push('보내는 주소: ' + (d.fromEmail || '없음'));
        var bad = (d.apiKey && d.apiKey.length !== 32) || (d.secretKey && d.secretKey.length !== 32);
        prog.className = bad ? 'prog err' : 'prog on';
        prog.textContent = lines.join('  |  ') + (bad ? '  ⚠️ 키는 보통 32자입니다. 길이를 확인해주세요.' : '');
      } catch(e) {
        prog.className = 'prog err';
        prog.textContent = '확인 실패: ' + e.message;
      }
    };
  }

  // 발신 주소 실시간 미리보기
  var nameIn = document.getElementById('mailNameInput');
  var localIn = document.getElementById('mailLocalInput');
  var pvName = document.getElementById('pvName');
  var pvAddr = document.getElementById('pvAddr');
  var DOMAIN = '<%= mailDomain || "" %>';
  function syncPreview(){
    if (pvName && nameIn) pvName.textContent = nameIn.value.trim() || (nameIn.placeholder.replace('예: ','') || '사주 풀이');
    if (pvAddr && localIn) {
      var v = localIn.value.toLowerCase().replace(/[^a-z0-9._-]/g, '');
      if (localIn.value !== v) localIn.value = v;
      pvAddr.textContent = '<' + (v || 'noreply') + '@' + DOMAIN + '>';
    }
  }
  if (nameIn) nameIn.addEventListener('input', syncPreview);
  if (localIn) localIn.addEventListener('input', syncPreview);

  var btnTest = document.getElementById('btnTestMail');
  if (btnTest) {
    btnTest.onclick = async function(){
      var prog = document.getElementById('mailProg');
      btnTest.disabled = true;
      var old = btnTest.textContent;
      btnTest.textContent = '보내는 중...';
      prog.className = 'prog on';
      prog.textContent = '테스트 메일을 보내는 중입니다... (최대 30초)';
      try {
        var toEl = document.getElementById('testTo');
        var r = await fetch('/api/mail/test', {
          method:'POST',
          headers:{'Content-Type':'application/json'},
          body: JSON.stringify({ to: toEl ? toEl.value : '' })
        });
        var d = await r.json();
        if (!d.ok) throw new Error((d.error || '실패') + (d.hint ? '  → ' + d.hint : ''));
        prog.className = 'prog ok';
        prog.textContent = '발송 성공! ' + d.to + ' 받은편지함을 확인해보세요.  (발신: ' + d.from + ')';
      } catch(e) {
        prog.className = 'prog err';
        prog.textContent = '발송 실패: ' + e.message;
      }
      btnTest.disabled = false;
      btnTest.textContent = old;
    };
  }

  function copyShare() {
    var el = document.getElementById('shareUrl');
    el.select();
    el.setSelectionRange(0, 99999);
    navigator.clipboard.writeText(el.value).then(function(){
      alert('링크가 복사되었습니다.');
    }, function(){
      document.execCommand('copy');
      alert('링크가 복사되었습니다.');
    });
  }
</script>

