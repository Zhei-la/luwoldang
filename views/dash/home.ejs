<%- include('../partials/dash-top', { user: user, active: active, title: '홈' }) %>

<p class="welcome">
  안녕하세요, <strong><%= user.name %></strong>님.<br>
  AI 사주 PDF 제작과 무료사주 상담 연결을 시작해보세요.
</p>


<!-- 신청 알림 -->
<div class="noti-box" id="notiBox" style="display:none">
  <div class="noti-l">
    <div class="noti-t">🔔 신청 알림</div>
    <div class="noti-d" id="notiDesc">손님이 사주를 신청하면 이 기기로 알림을 보내드립니다.</div>
  </div>
  <div class="noti-r">
    <button type="button" class="noti-btn" id="notiOn">알림 켜기</button>
    <button type="button" class="noti-btn ghost" id="notiTest" style="display:none">테스트</button>
    <button type="button" class="noti-btn ghost" id="notiOff" style="display:none">끄기</button>
  </div>
</div>

<style>
  .noti-box{display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap;
    background:#fbf6ec;border:1px solid #ecdfc4;border-radius:14px;padding:16px 20px;margin-bottom:20px}
  .noti-t{font-size:16px;font-weight:800;color:#33301f;margin-bottom:4px}
  .noti-d{font-size:13.5px;color:#8a6f3c;line-height:1.6}
  .noti-r{display:flex;gap:8px;flex-shrink:0}
  .noti-btn{padding:10px 18px;background:#B59A62;color:#fff;border:0;border-radius:9px;
    font-weight:800;font-size:13.5px;cursor:pointer;white-space:nowrap}
  .noti-btn.ghost{background:#fff;border:1px solid #ddd2b8;color:#8a6f3c;font-weight:700}
  .noti-btn:disabled{opacity:.5;cursor:default}
  @media(max-width:600px){ .noti-box{flex-direction:column;align-items:stretch} .noti-r{justify-content:flex-end} }
</style>

<script>
(function(){
  var box=document.getElementById('notiBox'), desc=document.getElementById('notiDesc');
  var bOn=document.getElementById('notiOn'), bOff=document.getElementById('notiOff'), bTest=document.getElementById('notiTest');
  var KEY='';
  var UA = navigator.userAgent || '';
  var INAPP = /KAKAOTALK|NAVER|Instagram|FBAN|FBAV|FB_IAB|Line\/|DaumApps|everytimeApp/i.test(UA);
  var IOS = /iPhone|iPad|iPod/i.test(UA);
  var STANDALONE = window.navigator.standalone === true
    || (window.matchMedia && window.matchMedia('(display-mode: standalone)').matches);

  function show(state, n){
    box.style.display='';
    if(state==='on'){
      desc.textContent='이 기기에서 알림을 받고 있습니다. (등록된 기기 ' + n + '개)';
      bOn.style.display='none'; bOff.style.display=''; bTest.style.display='';
    } else if(state==='denied'){
      desc.innerHTML='브라우저에서 알림이 <b>차단</b>되어 있습니다. 주소창 왼쪽 자물쇠 → 알림 → 허용으로 바꿔주세요.';
      bOn.style.display='none'; bOff.style.display='none'; bTest.style.display='none';
    } else if(state==='inapp'){
      desc.innerHTML='카카오톡·인스타그램 같은 <b>앱 안의 화면</b>에서는 알림을 켤 수 없습니다.<br>'
        + '오른쪽 위 <b>⋮ (점 세 개)</b> → <b>다른 브라우저로 열기</b> 를 눌러 '
        + (IOS ? '<b>사파리</b>' : '<b>크롬</b>') + '으로 연 뒤 다시 시도해주세요.';
      bOn.style.display='none'; bOff.style.display='none'; bTest.style.display='none';
    } else if(state==='ios-web'){
      desc.innerHTML='아이폰은 <b>홈 화면에 추가</b>한 뒤에만 알림을 받을 수 있습니다.<br>'
        + '사파리 아래 <b>공유 버튼</b> → <b>홈 화면에 추가</b> → 생긴 아이콘으로 들어와 알림을 켜주세요.';
      bOn.style.display='none'; bOff.style.display='none'; bTest.style.display='none';
    } else if(state==='unsupported'){
      desc.innerHTML='이 브라우저는 알림을 지원하지 않습니다. '
        + (IOS ? '<b>사파리</b>' : '<b>크롬</b>') + '으로 열어 다시 시도해주세요.';
      bOn.style.display='none'; bOff.style.display='none'; bTest.style.display='none';
    } else {
      desc.textContent='손님이 사주를 신청하면 이 기기로 알림을 보내드립니다.';
      bOn.style.display=''; bOff.style.display='none'; bTest.style.display='none';
    }
  }

  function b64(base64){
    var pad='='.repeat((4-base64.length%4)%4);
    var raw=atob((base64+pad).replace(/-/g,'+').replace(/_/g,'/'));
    return Uint8Array.from([].map.call(raw, function(c){ return c.charCodeAt(0); }));
  }

  async function init(){
    // 카카오톡·인스타 등 앱 안의 브라우저는 알림을 지원하지 않는다
    if(INAPP){ box.style.display=''; show('inapp'); return; }
    // 아이폰은 홈 화면에 추가해서 열었을 때만 알림이 된다
    if(IOS && !STANDALONE){ box.style.display=''; show('ios-web'); return; }
    if(!('serviceWorker' in navigator) || !('PushManager' in window)){ box.style.display=''; show('unsupported'); return; }
    var r;
    try { r = await (await fetch('/push/key')).json(); } catch(e){ return; }
    if(!r.ok || !r.ready || !r.key) return;   // 서버에 알림 설정이 없으면 숨김
    KEY = r.key;

    if(Notification.permission==='denied'){ show('denied'); return; }
    var reg = await navigator.serviceWorker.register('/sw.js');
    var sub = await reg.pushManager.getSubscription();
    show(sub ? 'on' : 'off', r.devices);

    bOn.onclick = async function(){
      bOn.disabled=true; bOn.textContent='켜는 중...';
      try{
        var perm = await Notification.requestPermission();
        if(perm!=='granted'){ show('denied'); return; }
        var reg2 = await navigator.serviceWorker.ready;
        var s = await reg2.pushManager.subscribe({ userVisibleOnly:true, applicationServerKey:b64(KEY) });
        var d = await (await fetch('/push/subscribe',{method:'POST',headers:{'Content-Type':'application/json'},
                 body:JSON.stringify({sub:s})})).json();
        if(!d.ok) throw new Error(d.error||'실패');
        show('on', d.devices);
        // 안드로이드에서는 new Notification() 이 막혀 있으므로 서비스워커로 띄운다
        try {
          await reg2.showNotification('루월당', {
            body: '이제 신청 알림을 받습니다 🎉',
            icon: '/img/push-icon.png',
            badge: '/img/push-icon.png',
          });
        } catch(e) { /* 알림 표시 실패는 무시 — 구독은 이미 완료됨 */ }
      }catch(e){ alert('알림을 켜지 못했습니다: ' + e.message); }
      bOn.disabled=false; bOn.textContent='알림 켜기';
    };

    bOff.onclick = async function(){
      bOff.disabled=true;
      try{
        var reg2 = await navigator.serviceWorker.ready;
        var s = await reg2.pushManager.getSubscription();
        if(s){ await fetch('/push/unsubscribe',{method:'POST',headers:{'Content-Type':'application/json'},
                 body:JSON.stringify({endpoint:s.endpoint})}); await s.unsubscribe(); }
        show('off');
      }catch(e){ alert('끄지 못했습니다: ' + e.message); }
      bOff.disabled=false;
    };

    bTest.onclick = async function(){
      bTest.disabled=true; bTest.textContent='보내는 중...';
      try{
        var d = await (await fetch('/push/test',{method:'POST'})).json();
        if(!d.ok) alert('알림을 보내지 못했습니다. 알림을 다시 켜보세요.');
      }catch(e){ alert('실패: ' + e.message); }
      bTest.disabled=false; bTest.textContent='테스트';
    };
  }
  init();
})();
</script>

<div class="card-grid">
  <a class="card" href="/pdf/create">
    <div class="card-t">PDF 만들기</div>
    <div class="card-d">내담자 정보 입력 → 7종 사주 리포트 제작</div>
  </a>
  <a class="card" href="/leads">
    <div class="card-t">사주 신청자</div>
    <div class="card-d">신청 확인 → 리포트 제작 → 발송</div>
  </a>
  <a class="card" href="/builder">
    <div class="card-t">내 웹사이트 만들기</div>
    <div class="card-d">랜딩 페이지를 꾸미고 링크 공유</div>
  </a>
  <a class="card" href="/records">
    <div class="card-t">발송 기록</div>
    <div class="card-d">리포트 · 이메일 발송 내역 확인</div>
  </a>
  <a class="card" href="/chat">
    <div class="card-t">내담자 추가질문</div>
    <div class="card-d">리포트 기반 AI 추가 상담</div>
  </a>
  <a class="card" href="/free-saju-settings">
    <div class="card-t">무료사주 · API 설정</div>
    <div class="card-d">OpenAI 키 · 이메일 발송 · 상담 링크</div>
  </a>
</div>

<h2 class="section-h">방문자 통계</h2>
<div class="stat-cards">
  <div class="stat-card">
    <div class="stat-label">오늘 방문</div>
    <div class="stat-num"><%= visit.visitToday %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">전체 방문</div>
    <div class="stat-num"><%= visit.visitTotal %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">무료사주 신청</div>
    <div class="stat-num"><%= visit.freeCnt %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">상담 신청</div>
    <div class="stat-num"><%= visit.consultCnt %></div>
  </div>
  <div class="stat-card accent">
    <div class="stat-label">방문 → 신청</div>
    <div class="stat-num"><%= visit.visitToLead %><span class="stat-unit">%</span></div>
  </div>
  <div class="stat-card accent">
    <div class="stat-label">신청 → 유료</div>
    <div class="stat-num"><%= visit.leadToPaid %><span class="stat-unit">%</span></div>
  </div>
</div>

<% if (visitAll) { %>
  <h2 class="section-h">전체 통계 (관리자)</h2>
  <div class="stat-cards">
    <div class="stat-card admin">
      <div class="stat-label">오늘 방문</div>
      <div class="stat-num"><%= visitAll.visitToday %></div>
    </div>
    <div class="stat-card admin">
      <div class="stat-label">전체 방문</div>
      <div class="stat-num"><%= visitAll.visitTotal %></div>
    </div>
    <div class="stat-card admin">
      <div class="stat-label">전체 신청</div>
      <div class="stat-num"><%= visitAll.totalLeads %></div>
    </div>
    <div class="stat-card admin">
      <div class="stat-label">유료 발송</div>
      <div class="stat-num"><%= visitAll.paidCount %></div>
    </div>
    <div class="stat-card admin accent">
      <div class="stat-label">방문 → 신청</div>
      <div class="stat-num"><%= visitAll.visitToLead %><span class="stat-unit">%</span></div>
    </div>
    <div class="stat-card admin accent">
      <div class="stat-label">신청 → 유료</div>
      <div class="stat-num"><%= visitAll.leadToPaid %><span class="stat-unit">%</span></div>
    </div>
  </div>
<% } %>

<style>
  .stat-cards { display:grid; grid-template-columns:repeat(auto-fill,minmax(140px,1fr)); gap:12px; margin-bottom:8px; }
  .stat-card { background:#fff; border:1px solid #e6e0d2; border-radius:12px; padding:16px 14px; text-align:center; }
  .stat-card.accent { background:#fbf6ec; border-color:#e6d9b8; }
  .stat-card.admin { background:#f4f1ff; border-color:#ddd6f3; }
  .stat-card.admin.accent { background:#efeaff; }
  .stat-label { font-size:12.5px; color:#8a8372; margin-bottom:8px; }
  .stat-num { font-size:26px; font-weight:800; color:#3a3527; }
  .stat-unit { font-size:15px; font-weight:600; color:#8a8372; margin-left:2px; }
</style>

<h2 class="section-h">최근 작업 현황</h2>
<div class="recent">
  <div class="recent-row"><span>제작한 리포트</span><em><%= stats.pdfs %>건</em></div>
  <div class="recent-row"><span>이메일 발송</span><em><%= stats.sent %>건</em></div>
  <div class="recent-row"><span>사주 신청자</span><em><%= stats.leads %>명</em></div>
  <div class="recent-row"><span>무료사주 조회</span><em><%= stats.free %>건</em></div>
</div>

