<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof title !== 'undefined' ? title : '홈' %> · 루월당</title>
  <!-- 홈 화면에 추가하면 앱처럼 쓸 수 있고, 아이폰에서도 알림을 받을 수 있다 -->
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#B59A62">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-title" content="루월당">
  <link rel="apple-touch-icon" href="/img/push-icon.png">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
<% if (typeof adminAs !== 'undefined' && adminAs) { %>
  <div class="as-bar">
    <span class="as-txt">👤 <b><%= adminAs.viewing %></b> 님 계정으로 보는 중입니다</span>
    <a class="as-back" href="/auth/back">관리자로 돌아가기</a>
  </div>
  <style>
    .as-bar{display:flex;align-items:center;justify-content:center;gap:14px;flex-wrap:wrap;
      background:#5b4a8a;color:#fff;padding:9px 14px;font-size:13.5px}
    .as-txt b{color:#ffe9a8}
    .as-back{background:#fff;color:#4a3d6b;padding:5px 13px;border-radius:20px;
      font-size:12.5px;font-weight:800;text-decoration:none;white-space:nowrap}
    .as-back:hover{background:#ffe9a8}
  </style>
<% } %>
<% if (typeof testSwitch !== 'undefined' && testSwitch) { %>
  <div class="test-switch-bar">
    <span class="tsb-label">🧪 테스트</span>
    <% testSwitch.accounts.forEach(function (u) { %>
      <% if (u === testSwitch.current) { %>
        <span class="tsb-chip on"><%= u %></span>
      <% } else { %>
        <a class="tsb-chip" href="/auth/switch?to=<%= encodeURIComponent(u) %>"><%= u %></a>
      <% } %>
    <% }); %>
  </div>
  <style>
    .test-switch-bar{position:sticky;top:0;z-index:200;display:flex;align-items:center;gap:6px;
      flex-wrap:wrap;padding:7px 12px;background:#241a06;color:#e8e3d6;font-size:12.5px;
      font-family:-apple-system,'Malgun Gothic',sans-serif}
    .tsb-label{font-weight:800;color:#c8a45c;margin-right:4px}
    .tsb-chip{padding:4px 11px;border-radius:20px;background:#3a3527;color:#e8e3d6;
      text-decoration:none;font-weight:600}
    .tsb-chip.on{background:#c8a45c;color:#241a06;font-weight:800}
    .tsb-chip:hover{background:#4a4436}
    .tsb-chip.on:hover{background:#c8a45c}
  </style>
<% } %>

<div class="layout">
  <div class="overlay" id="overlay" onclick="closeSidebar()"></div>

  <aside class="sidebar" id="sidebar">
    <div class="brand-mini">루월당</div>
    <nav>
      <%
        const menu = [
          { key: 'home',    href: '/home',               label: '홈' },
          { key: 'free',    href: '/builder',            label: '내 웹사이트 만들기' },
          { key: 'leads',   href: '/leads',              label: '사주 신청자' },
          { key: 'pdf',     href: '/pdf/create',         label: 'PDF 만들기' },
          { key: 'chat',    href: '/chat',               label: '내담자 추가질문' },
          { key: 'reviews', href: '/reviews',            label: '후기' },
          { key: 'covers',  href: '/covers',             label: 'PDF 표지 꾸미기' },
          { key: 'records', href: '/records',            label: 'PDF · 이메일 발송 기록' },
          { key: 'settings',href: '/free-saju-settings', label: '무료사주 · API 설정' },
          { key: 'account', href: '/account',            label: '내 계정' }
        ];
      %>
      <% menu.forEach(function (m) { %>
        <a href="<%= m.href %>" class="nav-item <%= active === m.key ? 'active' : '' %>"><%= m.label %></a>
      <% }); %>

      <% if (user.role === 'admin') { %>
        <div class="nav-sep">관리자</div>
        <a href="/admin/approvals" class="nav-item <%= active === 'admin' ? 'active' : '' %>">회원 승인 · 관리</a>
        <a href="/admin/covers" class="nav-item <%= active === 'admin-covers' ? 'active' : '' %>">기본 표지 관리</a>
      <% } %>
    </nav>
    <form method="post" action="/logout" class="logout-form">
      <button type="submit" class="logout-btn">로그아웃</button>
    </form>
  </aside>

  <div class="content">
    <header class="topbar">
      <button class="hamburger" onclick="openSidebar()" aria-label="메뉴">☰</button>
      <h1 class="page-title"><%= typeof title !== 'undefined' ? title : '홈' %></h1>
      <span class="who"><%= user.name %> · <%= user.role === 'admin' ? '관리자' : '교육생' %></span>
    </header>
    <main class="main">
