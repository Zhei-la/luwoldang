<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof title !== 'undefined' ? title : '홈' %> · 루월당</title>
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
<div class="layout">
  <div class="overlay" id="overlay" onclick="closeSidebar()"></div>

  <aside class="sidebar" id="sidebar">
    <div class="brand-mini">루월당</div>
    <nav>
      <%
        const menu = [
          { key: 'home',    href: '/home',               label: '홈' },
          { key: 'free',    href: '/builder',            label: '내 웹사이트 만들기' },
          { key: 'leads',   href: '/leads',              label: '사주 신청자' },
          { key: 'pdf',     href: '/pdf/create',         label: 'PDF 만들기' },
          { key: 'chat',    href: '/chat',               label: '내담자 추가질문' },
          { key: 'reviews', href: '/reviews',            label: '후기' },
          { key: 'records', href: '/records',            label: 'PDF · 이메일 발송 기록' },
          { key: 'settings',href: '/free-saju-settings', label: '무료사주 · API 설정' },
          { key: 'account', href: '/account',            label: '내 계정' }
        ];
      %>
      <% menu.forEach(function (m) { %>
        <a href="<%= m.href %>" class="nav-item <%= active === m.key ? 'active' : '' %>"><%= m.label %></a>
      <% }); %>

      <% if (user.role === 'admin') { %>
        <div class="nav-sep">관리자</div>
        <a href="/admin/approvals" class="nav-item <%= active === 'admin' ? 'active' : '' %>">회원 승인 · 관리</a>
      <% } %>
    </nav>
    <form method="post" action="/logout" class="logout-form">
      <button type="submit" class="logout-btn">로그아웃</button>
    </form>
  </aside>

  <div class="content">
    <header class="topbar">
      <button class="hamburger" onclick="openSidebar()" aria-label="메뉴">☰</button>
      <h1 class="page-title"><%= typeof title !== 'undefined' ? title : '홈' %></h1>
      <span class="who"><%= user.name %> · <%= user.role === 'admin' ? '관리자' : '교육생' %></span>
    </header>
    <main class="main">
