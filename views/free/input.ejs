<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= teacher.site_name || '무료 사주' %></title>
  <link rel="stylesheet" href="/css/free.css">
</head>
<body class="free-body">
  <div class="free-wrap">
    <div class="free-card">
      <div class="moon"></div>
      <h1 class="free-title"><%= teacher.site_name || '무료 사주' %></h1>
      <div class="free-line"></div>
      <p class="free-intro">간단한 정보를 입력하면<br>나의 기본 사주와 올해 흐름을 무료로 확인할 수 있습니다.</p>

      <% if (error) { %><div class="free-error"><%= error %></div><% } %>

      <form method="post" action="/s/<%= teacher.slug %>/free/result" onsubmit="return onSubmit()" novalidate>
        <label class="fl">이름</label>
        <input class="fi" type="text" name="name" value="<%= form.name || '' %>" placeholder="홍길동" required>

        <label class="fl">성별</label>
        <div class="seg">
          <label class="seg-item"><input type="radio" name="gender" value="남" <%= form.gender === '남' ? 'checked' : '' %> required> 남성</label>
          <label class="seg-item"><input type="radio" name="gender" value="여" <%= form.gender === '여' ? 'checked' : '' %>> 여성</label>
        </div>

        <label class="fl">생년월일</label>
        <input class="fi" type="date" name="birthDate" value="<%= form.birthDate || '' %>" min="1930-01-01" max="2025-12-31" required>

        <label class="fl">달력</label>
        <div class="seg seg3">
          <label class="seg-item"><input type="radio" name="calendar" value="양력" <%= (form.calendar || '양력') === '양력' ? 'checked' : '' %>> 양력</label>
          <label class="seg-item"><input type="radio" name="calendar" value="음력" <%= form.calendar === '음력' ? 'checked' : '' %>> 음력</label>
          <label class="seg-item"><input type="radio" name="calendar" value="윤달" <%= form.calendar === '윤달' ? 'checked' : '' %>> 윤달</label>
        </div>

        <label class="fl">태어난 시간</label>
        <input class="fi" type="time" name="birthTime" id="birthTime" value="<%= form.birthTime || '' %>">
        <label class="chk"><input type="checkbox" name="timeUnknown" id="timeUnknown" onchange="toggleTime()" <%= form.timeUnknown ? 'checked' : '' %>> 태어난 시간을 몰라요</label>

        <label class="fl">태어난 지역</label>
        <select class="fi" name="region">
          <% var regions = ['서울특별시','인천광역시','경기도','강원도','대전광역시','세종특별자치시','충청북도','충청남도','광주광역시','전라북도','전라남도','대구광역시','경상북도','부산광역시','울산광역시','경상남도','제주특별자치도']; %>
          <% regions.forEach(function(r){ %>
            <option value="<%= r %>" <%= (form.region || '서울특별시') === r ? 'selected' : '' %>><%= r %></option>
          <% }); %>
        </select>
        <p class="hint-sm">지역에 따라 실제 태어난 시각(진태양시)이 보정됩니다.</p>

        <label class="fl">이메일</label>
        <input class="fi" type="email" name="email" value="<%= form.email || '' %>" placeholder="example@naver.com" required>
        <p class="hint-sm">이 이메일로 사주 풀이 결과를 보내드립니다.</p>

        <label class="chk agree"><input type="checkbox" name="agree" value="1" required> 개인정보 수집 및 이용에 동의합니다.</label>

        <button class="free-btn" type="submit">무료사주 결과 보기</button>
      </form>
    </div>
    <p class="free-foot">본 사주 풀이는 참고용 콘텐츠입니다.</p>
  </div>

  <div class="loading" id="loading">
    <div class="loading-box">
      <div class="spinner"></div>
      <p>사주 내용을 분석하고 있습니다...</p>
      <span>잠시만 기다려 주세요 (약 10초)</span>
    </div>
  </div>

  <script>
    function toggleTime() {
      var t = document.getElementById('birthTime');
      var u = document.getElementById('timeUnknown');
      t.disabled = u.checked;
      if (u.checked) t.value = '';
    }

    var LABELS = { name:'이름', gender:'성별', birthDate:'생년월일', email:'이메일' };

    function boxOf(el){
      var p = el.parentNode;
      // 라디오는 .seg 컨테이너, 나머지는 폼 자체
      if (el.type === 'radio') return el.closest('.seg') || p;
      if (el.type === 'checkbox') return el.closest('.chk') || p;
      return el;
    }
    function clearErr(){
      document.querySelectorAll('.errmsg').forEach(function(e){ e.remove(); });
      document.querySelectorAll('.errfield').forEach(function(e){ e.classList.remove('errfield'); });
      var b = document.querySelector('.formerr'); if(b) b.remove();
    }
    function showErr(el, msg){
      var box = boxOf(el);
      box.classList.add('errfield');
      var d = document.createElement('div');
      d.className = 'errmsg';
      d.textContent = msg;
      var anchor = (el.type === 'radio' || el.type === 'checkbox') ? box : el;
      anchor.parentNode.insertBefore(d, anchor.nextSibling);
    }

    function onSubmit() {
      clearErr();
      var f = document.querySelector('form');
      var missing = [], first = null;

      f.querySelectorAll('[required]').forEach(function(el){
        var ok;
        if (el.type === 'radio') ok = f.querySelector('input[name="'+el.name+'"]:checked');
        else if (el.type === 'checkbox') ok = el.checked;
        else ok = el.value && el.value.trim();

        if (!ok) {
          var isAgree = el.name === 'agree';
          var label = isAgree ? '개인정보 수집 동의' : (LABELS[el.name] || '필수 항목');
          if (missing.indexOf(label) < 0) {
            missing.push(label);
            showErr(el, isAgree ? '동의가 필요합니다.' : label + '을(를) 입력해주세요.');
            if (!first) first = el;
          }
        }
      });

      if (missing.length) {
        var bar = document.createElement('div');
        bar.className = 'formerr';
        bar.textContent = missing.join(', ') + ' 항목을 확인해주세요.';
        f.insertBefore(bar, f.firstChild);
        (first ? boxOf(first) : bar).scrollIntoView({ behavior:'smooth', block:'center' });
        return false;
      }

      document.getElementById('loading').classList.add('show');
      return true;
    }

    document.addEventListener('input', function(e){
      var b = boxOf(e.target);
      if (b.classList) b.classList.remove('errfield');
      var n = b.nextElementSibling;
      if (n && n.className === 'errmsg') n.remove();
    }, true);
    document.addEventListener('change', function(e){
      var b = boxOf(e.target);
      if (b.classList) b.classList.remove('errfield');
      var n = b.nextElementSibling;
      if (n && n.className === 'errmsg') n.remove();
    }, true);

    toggleTime();
  </script>
</body>
</html>
