<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= teacher.site_name || '무료 사주' %> · 결과</title>
  <link rel="stylesheet" href="/css/free.css">
</head>
<body class="free-body">
  <div class="free-wrap">
    <div class="free-card result">

      <% if (error) { %>
        <div class="moon"></div>
        <h1 class="free-title">무료 사주</h1>
        <div class="free-line"></div>
        <div class="free-error"><%= error %></div>
        <a class="free-btn ghost" href="/s/<%= teacher.slug %>/free">다시 시도하기</a>

      <% } else { %>
        <div class="moon"></div>
        <h1 class="free-title"><%= teacher.site_name || '무료 사주' %></h1>
        <div class="free-line"></div>

        <!-- 원국 표 -->
        <div class="chart-head">
          <h2 class="chart-name"><%= input.name %></h2>
          <p class="chart-day"><%= saju.pillarsKo.day %><span><%= saju.pillars.day %></span></p>
          <div class="chart-meta">
            <p><b class="tag-solar">양</b> <%= saju.solarDate.replace(/-/g,'/') %> <%= saju.timeCorrection.originalTime || '시간모름' %> <%= input.gender || '' %> <%= input.region || '' %></p>
            <% if (saju.timeCorrection.correctedTime && saju.timeCorrection.correctionMinutes !== 0) { %>
              <p class="corr"><b class="tag-solar">양</b> <%= saju.solarDate.replace(/-/g,'/') %> <%= saju.timeCorrection.correctedTime %> <%= input.region || '' %> (<%= saju.timeCorrection.notes.join(', ') %>)</p>
            <% } %>
          </div>
        </div>

        <div class="chart-scroll">
          <table class="chart">
            <thead>
              <tr>
                <th></th>
                <th>생시</th>
                <th>생일</th>
                <th>생월</th>
                <th>생년</th>
              </tr>
            </thead>
            <tbody>
              <% var cols = ['hour','day','month','year']; %>
              <tr>
                <th class="rowh">천간</th>
                <% cols.forEach(function(c){ var s = saju.detail[c].stem; %>
                  <td>
                    <% if (s) { %>
                      <div class="gz el-<%= s.el %>">
                        <span class="ko"><%= s.ko %></span><span class="hj"><%= s.char %></span>
                      </div>
                      <div class="ee el-<%= s.el %>"><%= s.yin ? '-' : '+' %><%= s.el %></div>
                    <% } else { %><div class="none">미상</div><% } %>
                  </td>
                <% }); %>
              </tr>
              <tr class="god-row">
                <th class="rowh sub">십성</th>
                <% cols.forEach(function(c){ var s = saju.detail[c].stem; %>
                  <td><span class="god <%= s ? 'el-' + s.el : '' %>"><%= s ? s.god : '—' %></span></td>
                <% }); %>
              </tr>
              <tr>
                <th class="rowh">지지</th>
                <% cols.forEach(function(c){ var b = saju.detail[c].branch; %>
                  <td>
                    <% if (b) { %>
                      <div class="gz el-<%= b.el %>">
                        <span class="ko"><%= b.ko %></span><span class="hj"><%= b.char %></span>
                      </div>
                      <div class="ee el-<%= b.el %>"><%= b.yin ? '-' : '+' %><%= b.el %></div>
                    <% } else { %><div class="none">미상</div><% } %>
                  </td>
                <% }); %>
              </tr>
              <tr class="god-row">
                <th class="rowh sub">십성</th>
                <% cols.forEach(function(c){ var b = saju.detail[c].branch; %>
                  <td><span class="god <%= b ? 'el-' + b.el : '' %>"><%= b ? b.god : '—' %></span></td>
                <% }); %>
              </tr>
              <tr class="god-row">
                <th class="rowh sub">지장간</th>
                <% cols.forEach(function(c){ var jj = saju.detail[c].jijanggan || []; %>
                  <td>
                    <% if (jj.length) { %>
                      <span class="jj">
                        <% jj.forEach(function(g){ %><i class="el-<%= g.el %>"><%= g.ko %></i><% }); %>
                      </span>
                    <% } else { %><span class="god">—</span><% } %>
                  </td>
                <% }); %>
              </tr>
              <tr class="god-row">
                <th class="rowh sub">12운성</th>
                <% cols.forEach(function(c){ var u = saju.detail[c].unseong; %>
                  <td><span class="god"><%= u || '—' %></span></td>
                <% }); %>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- 오행 오각형 -->
        <% if (saju.elementWheel) { %>
          <%- include('../partials/element-wheel', {
                wheel: saju.elementWheel,
                dayMasterKo: saju.dayMasterKo,
                dayMasterElement: saju.dayMasterElement }) %>
        <% } %>
        <p class="el-sum">강한 기운 <em><%= saju.strong.join(', ') %></em> · 부족한 기운 <em><%= saju.weak.join(', ') %></em></p>

        <% if (saju.daewoon && saju.daewoon.list.length) { %>
          <div class="dw">
            <div class="dw-title">대운 <span><%= saju.daewoon.forward ? '순행' : '역행' %></span></div>
            <div class="dw-scroll">
              <div class="dw-row">
                <% saju.daewoon.list.forEach(function(d){ %>
                  <div class="dw-item">
                    <span class="dw-age"><%= d.age %></span>
                    <b class="dw-gz"><%= d.ko %></b>
                    <i class="dw-hj"><%= d.ganzi %></i>
                  </div>
                <% }); %>
              </div>
            </div>
          </div>
        <% } %>

        <% function para(t){ return String(t || '').split(/\n{2,}|\n/).filter(Boolean); } %>

        <% if (typeof mailSent !== 'undefined' && mailSent && input && input.email) { %>
          <div class="mail-ok">✓ <b><%= input.email %></b> 로 사주 풀이를 보내드렸습니다.</div>
        <% } %>

        <!-- 핵심 키워드 -->
        <% if (result.keywords && result.keywords.length) { %>
          <div class="kw-row">
            <% result.keywords.slice(0,3).forEach(function(k){ %>
              <span class="kw"><%= k %></span>
            <% }); %>
          </div>
        <% } %>

        <!-- 요약 미리보기 — 각 섹션 첫 문단만. 전문은 PDF에서 -->
        <% function lead(t){ var a = para(t); return a.length ? a[0] : ''; } %>

        <div class="rsec">
          <h3><span class="num">01</span> 내 사주 한눈에 보기</h3>
          <p><%= lead(result.manse) %></p>
        </div>

        <div class="rsec">
          <h3><span class="num">02</span> 사주로 보는 나는?</h3>
          <p><%= lead(result.self) %></p>
        </div>

        <div class="rsec">
          <h3><span class="num">03</span> 타고난 성향</h3>
          <p><%= lead(result.personality) %></p>
        </div>

        <div class="rsec">
          <h3><span class="num">04</span> 올해 운세</h3>
          <p><%= lead(result.year) %></p>
        </div>

        <div class="rsec">
          <h3><span class="num">05</span> 연애운</h3>
          <p><%= lead(result.love) %></p>
        </div>

        <div class="rsec">
          <h3><span class="num">06</span> 재물운</h3>
          <p><%= lead(result.wealth) %></p>
        </div>

        <div class="rsec">
          <h3><span class="num">07</span> 건강운</h3>
          <p><%= lead(result.health) %></p>
          <small class="disc">※ 명리학적 관점의 생활 경향 해석이며 의학적 진단이나 치료를 대신하지 않습니다.</small>
        </div>

        <div class="rsec advice">
          <h3><span class="num">08</span> 종합 조언</h3>
          <p><%= lead(result.advice) %></p>
        </div>

        <!-- PDF 안내 -->
        <div class="pdf-box">
          <div class="pdf-h">여기까지는 요약입니다</div>
          <p>
            위 내용은 각 항목의 첫 부분만 보여드린 것입니다.<br>
            <b>만세력 해설</b>, <b>사주로 보는 나는?</b>, 각 운세의 <b>전체 풀이</b>는
            리포트에 모두 담겨 있습니다.
          </p>
          <a class="pdf-btn" href="/free/<%= logId %>/pdf" target="_blank">전체 리포트 PDF로 받기</a>
        </div>

        <!-- 08 더 자세한 사주 풀이 -->
        <div class="upsell">
          <h3>더 자세한 사주 풀이</h3>
          <% upsell.intro.split('\n').forEach(function(t){ %><p class="up-intro"><%= t %></p><% }); %>
          <ul class="up-list">
            <% upsell.items.forEach(function(it){ %><li><%= it %></li><% }); %>
          </ul>
          <div class="up-closing">
            <% upsell.closing.split('\n').forEach(function(t){ %><p><%= t %></p><% }); %>
          </div>
        </div>

        <!-- 상담 연결 -->
        <div class="cta">
          <p class="cta-msg"><%= teacher.consult_message || '무료사주는 전체 흐름을 간단히 보는 용도입니다. 내 사주를 더 자세히 알고 싶다면 전문 상담을 받아보세요.' %></p>
          <a class="cta-btn" href="/free/go/<%= logId %>"><%= teacher.button_text || '카카오톡으로 자세히 상담받기' %></a>
        </div>

        <a class="free-btn ghost" href="/s/<%= teacher.slug %>/free">처음으로</a>
      <% } %>
    </div>
  </div>
</body>
</html>
