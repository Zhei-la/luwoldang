# ===== 서버 =====
PORT=3000
NODE_ENV=development
# 로컬은 http://localhost:3000, 배포 후엔 https://내앱.up.railway.app 로 바꾸기
BASE_URL=http://localhost:3000
# 아무 긴 랜덤 문자열 (예: openssl rand -hex 32)
SESSION_SECRET=여기에_긴_랜덤_문자열

# ===== DB (Railway Postgres 또는 Supabase) =====
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ===== 카카오 로그인 =====
KAKAO_REST_KEY=카카오_REST_API_키
# Client Secret을 "발급/활성화" 했을 때만 채우기. 안 했으면 비워둘 것.
KAKAO_CLIENT_SECRET=

# ===== 관리자 승격 키 =====
# 카카오로 로그인한 뒤 /auth/admin?key=<이 값> 을 열면 그 계정이 관리자가 됩니다.
# 길고 추측 불가능한 값으로. (예: openssl rand -hex 24)
# 관리자 지정이 끝나면 이 변수를 지워도 됩니다.
ADMIN_KEY=여기에_긴_랜덤_문자열
